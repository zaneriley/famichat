# =============================================================================
# Famichat — Production Environment Variables
# =============================================================================
#
# Copy this file to .env.production and fill in all values:
#   cp .env.production.example .env.production
#   chmod 0600 .env.production
#
# Variables without defaults will cause the server to crash if missing.
#
# Generate secrets with: ./run secret (or: openssl rand -base64 64)
#
# === QUICK REFERENCE ===
# REQUIRED (server won't start without these):
# - URL_HOST, WEBAUTHN_RP_NAME
# - SECRET_KEY_BASE, UNIQUE_CONVERSATION_KEY_SALT
# - MLS_SNAPSHOT_HMAC_KEY, FAMICHAT_VAULT_KEY
# - POSTGRES_USER, POSTGRES_PASSWORD
#
# OPTIONAL (have sane defaults):
# - URL_SCHEME (default: https), URL_PORT (default: 443)
# - POSTGRES_HOST (default: postgres), POSTGRES_PORT (default: 5432)
# - PORT (default: 8001)
# =============================================================================

# --- Required: Your domain ----------------------------------------------------
# Start here. The #1 misconfiguration is a mismatch between these values.
#
# 1. Set URL_HOST to the domain your users will visit.
# 2. WEBAUTHN_RP_ID must exactly equal URL_HOST (passkeys will fail otherwise).
# 3. WEBAUTHN_ORIGIN is derived: URL_SCHEME + "://" + URL_HOST
#
# Example: if your domain is "chat.smith.family"
#   URL_HOST=chat.smith.family
#   WEBAUTHN_RP_ID=chat.smith.family
#   WEBAUTHN_ORIGIN=https://chat.smith.family
#
# If you change your domain later, update all three values and recreate the
# container. They must exactly match the URL your users visit, or passkeys
# will fail with an origin / relying-party mismatch.

export URL_HOST=chat.example.com
export URL_SCHEME=https
export URL_PORT=443

export WEBAUTHN_RP_ID=chat.example.com
export WEBAUTHN_ORIGIN=https://chat.example.com

# Human-readable name shown in passkey prompts (e.g. "Smith Family Chat").
export WEBAUTHN_RP_NAME=Famichat

# --- Required: Database ------------------------------------------------------
#
# Option 1 (recommended): Individual credentials
export POSTGRES_USER=famichat
# Generate with: openssl rand -base64 32
# Do not use the literal value "password" — it is rejected as a safeguard.
# NOTE: On first boot the password is baked into the Docker volume. If you
# change it later, you must also run ALTER USER inside the running database.
# Fresh deployments (new volume) are not affected.
export POSTGRES_PASSWORD=
export POSTGRES_DB=famichat
export POSTGRES_HOST=postgres
export POSTGRES_PORT=5432
#
# Option 2: Full connection string (overrides individual vars if set)
# export DATABASE_URL=postgresql://user:password@host:5432/famichat

# --- Required: Application secrets -------------------------------------------

# A random string of 64+ characters. Generate with: ./run secret
export SECRET_KEY_BASE=

# Used to generate unique conversation identifiers.
# Generate with: openssl rand -base64 32
export UNIQUE_CONVERSATION_KEY_SALT=

# --- Required: Encryption keys -----------------------------------------------

# HMAC key for MLS snapshot integrity verification.
# Must be at least 32 bytes. Can be base64-encoded or raw hex.
#
# Option 1 (recommended): Base64-encoded
#   openssl rand -base64 32
# Option 2: Raw hex (64 hex chars = 32 bytes)
#   openssl rand -hex 32
export MLS_SNAPSHOT_HMAC_KEY=

# AES-256-GCM key for Cloak vault encryption (encrypted fields in DB).
# Must be exactly 32 bytes, base64-encoded.
# Generate with: openssl rand -base64 32
export FAMICHAT_VAULT_KEY=

# --- Optional: Web server port ------------------------------------------------
# Internal port for the Phoenix web server (Cowboy).
# Default: 8001
# export PORT=8001

# --- Optional: Docker ---------------------------------------------------------

export COMPOSE_PROJECT_NAME=famichat

# Docker port mapping (external:internal). Maps host port to container PORT.
export DOCKER_WEB_PORT_FORWARD=127.0.0.1:8001

# --- Optional: Mix/Node environment ------------------------------------------

export MIX_ENV=prod
export NODE_ENV=production

# --- Optional: Access control -------------------------------------------------

# Allow strangers to create new family spaces via /families/new.
# Default: false in production (invite-only). Set to true if you want to run
# a community server where anyone can sign up.
# export REGISTRATION_OPEN=false

# --- Advanced -----------------------------------------------------------------
# Most operators should leave these unset.

# Server-side MLS enforcement. This controls the server-side MLS layer, which
# is NOT real end-to-end encryption (the server holds keys). Full client-side
# E2EE is a future milestone. Default: false. Leave unset for L1 deployments.
# export FAMICHAT_MLS_ENFORCEMENT=false
