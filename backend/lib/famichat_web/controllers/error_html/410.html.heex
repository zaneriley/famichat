<div class="min-h-screen flex items-center justify-center">
  <div
    class=""
    style="filter: url('#waves');transform: translateY(-0.25rem) translateX(calc(0rem));"
  >
    <h1>
      <%= gettext("This invite link didn't work") %>
    </h1>
    <p>
      <%= gettext("Your invite link has expired or has already been used.") %>
    </p>
    <p>
      <%= gettext("Ask the person who sent you the invite to send a new one. They can generate a fresh link anytime.") %>
    </p>
    <p>
      <a
        href={"/#{@conn.assigns[:user_locale] || "en"}/"}
        class="pb-6 block"
      >
        <%= gettext("Return to Famichat") %>
      </a>
    </p>

    <svg
      class="waves absolute top-0 left-0"
      xmlns="http://www.w3.org/2000/svg"
      version="1.1"
    >
      <defs>
        <filter id="waves">
          <feturbulence
            baseFrequency="0.0015"
            numOctaves="5"
            result="noise"
            seed="2"
          >
          </feturbulence>

          <fedisplacementmap
            id="displacement"
            in="SourceGraphic"
            in2="noise"
            scale="50"
          >
          </fedisplacementmap>
        </filter>
      </defs>
    </svg>
  </div>
</div>
