}

function _qa_project_root {
  cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

function _qa_require_host_command {
  local command_name="$1"
  local install_hint="$2"

  if ! command -v "${command_name}" >/dev/null 2>&1; then
    echo "Missing required host command: ${command_name}. ${install_hint}" >&2
    return 1
  fi
}

function _qa_ws_base_url {
  local base_url="${1:-http://localhost:8002}"
  local normalized_base_url="${base_url%/}"

  if [[ -n "${QA_WS_URL:-}" ]]; then
    echo "${QA_WS_URL}"
    return
  fi

  if [[ "${normalized_base_url}" == http://* ]]; then
    echo "${normalized_base_url/http:\/\//ws://}/socket/websocket?vsn=2.0.0"
    return
  fi

  if [[ "${normalized_base_url}" == https://* ]]; then
    echo "${normalized_base_url/https:\/\//wss://}/socket/websocket?vsn=2.0.0"
    return
  fi

  echo "${normalized_base_url}/socket/websocket?vsn=2.0.0"
}

function _qa_base_url {
  if [[ -n "${QA_BASE_URL:-}" ]]; then
    echo "${QA_BASE_URL}"
    return
  fi

  local mapped_port=""
  local candidate_container_port
  local -a candidates=(8002 8001 4000)
  for candidate_container_port in "${candidates[@]}"; do
    mapped_port="$(docker compose port web "${candidate_container_port}" 2>/dev/null | head -n 1 || true)"
    if [[ -n "${mapped_port}" ]]; then
      break
    fi
  done

  if [[ -z "${mapped_port}" ]]; then
    echo "http://localhost:8002"
    return
  fi

  local host="${mapped_port%:*}"
  local port="${mapped_port##*:}"

  if [[ "${host}" == "0.0.0.0" || "${host}" == "::" || "${host}" == "[::]" ]]; then
    host="localhost"
  fi

  host="${host#[}"
  host="${host%]}"

  echo "http://${host}:${port}"
}

function _qa_status_matches {
  local actual_status="$1"
  local expected_csv="$2"
  local expected

  IFS=',' read -r -a expected <<< "${expected_csv}"

  local status
  for status in "${expected[@]}"; do
    if [[ "${actual_status}" == "${status}" ]]; then
      return 0
    fi
  done

  return 1
}

function _qa_message_count {
  local base_url="$1"
  local token="$2"
  local conversation_id="$3"
  local output_file="$4"

  if ! curl -sS \
    --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
    --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
    -H "Authorization: Bearer ${token}" \
    "${base_url}/api/v1/conversations/${conversation_id}/messages" \
    > "${output_file}"; then
    echo "-1"
    return
  fi

  jq -r 'if (.data | type) == "array" then (.data | length) else -1 end' \
    "${output_file}" 2>/dev/null || echo "-1"
}

function _qa_message_match_token {
  local response_file="$1"
  local match_token=""
  local message_id=""

  if [[ -f "${response_file}" ]]; then
    message_id="$(
      jq -r '.data.payload.message_id // .payload.message_id // empty' \
        "${response_file}" 2>/dev/null || true
    )"
  fi

  if [[ -n "${message_id}" && "${message_id}" != "null" &&
    "${message_id}" != "empty" ]]; then
    match_token="${message_id}"
  fi

  echo "${match_token}"
}

function _qa_recover_conversation_state {
  local base_url="$1"
  local token="$2"
  local conversation_id="$3"
  local recovery_ref="$4"
  local output_file="$5"
  local request_file="${output_file}.request.json"

  jq -n \
    --arg recovery_ref "${recovery_ref}" \
    --arg rejoin_token "${recovery_ref}-rejoin" \
    --arg recovery_reason "qa_matrix_preseed" \
    '{
      recovery_ref: $recovery_ref,
      rejoin_token: $rejoin_token,
      recovery_reason: $recovery_reason
    }' > "${request_file}"

  local status
  status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${output_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/v1/conversations/${conversation_id}/security/recover" \
      -H "Authorization: Bearer ${token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${request_file}" || true
  )"

  if [[ -z "${status}" || "${status}" == "000" ]]; then
    status="-1"
  fi

  echo "${status}"
}

function _qa_spawn_ws_listener {
  local ws_url="$1"
  local ws_topic="$2"
  local output_file="$3"
  local wait_seconds="${4:-4}"
  local ready_file="${5:-}"

  node - "${ws_url}" "${ws_topic}" "${output_file}" "${wait_seconds}" "${ready_file}" <<'NODE' &
const fs = require("fs");

const [url, topic, outputFile, waitSecondsRaw, readyFile] = process.argv.slice(2);
const waitMs = Math.max(1000, Number(waitSecondsRaw || "4") * 1000);
const events = [];
let readyWritten = false;
let closeTimer = null;
let finished = false;

const preReadyTimeoutMs = readyFile ? waitMs + 5000 : waitMs;

function finish() {
  if (finished) {
    return;
  }

  finished = true;

  try {
    ws.close();
  } catch (error) {
    pushEvent({close_error: String(error)});
  }

  fs.writeFileSync(outputFile, events.join("\n"), "utf8");
  process.exit(0);
}

function scheduleClose(delayMs) {
  if (closeTimer) {
    clearTimeout(closeTimer);
  }

  closeTimer = setTimeout(finish, delayMs);
}

function markReady() {
  if (readyWritten || !readyFile) {
    return;
  }

  try {
    fs.writeFileSync(readyFile, new Date().toISOString(), "utf8");
    readyWritten = true;
    scheduleClose(waitMs);
  } catch (_error) {
    // Best effort only; QA assertions still rely on captured WS logs.
  }
}

function pushEvent(value) {
  if (typeof value === "string") {
    events.push(value);
    return;
  }

  events.push(JSON.stringify(value));
}

const ws = new WebSocket(url);

scheduleClose(preReadyTimeoutMs);

ws.addEventListener("open", () => {
  const joinPayload = JSON.stringify(["1", "1", topic, "phx_join", {}]);
  ws.send(joinPayload);
});

ws.addEventListener("message", (event) => {
  if (typeof event.data === "string") {
    pushEvent(event.data);
    try {
      const decoded = JSON.parse(event.data);
      if (Array.isArray(decoded) && decoded[3] === "phx_reply" && decoded[4] && decoded[4].status === "ok") {
        markReady();
      }
    } catch (_error) {
      // ignore non-JSON or non-phx frames
    }
    return;
  }

  const text = Buffer.from(event.data).toString("utf8");
  pushEvent(text);
  try {
    const decoded = JSON.parse(text);
    if (Array.isArray(decoded) && decoded[3] === "phx_reply" && decoded[4] && decoded[4].status === "ok") {
      markReady();
    }
  } catch (_error) {
    // ignore non-JSON or non-phx frames
  }
});

ws.addEventListener("error", (event) => {
  pushEvent({error: event.message || "ws_error"});
});

NODE
  _qa_ws_listener_pid="$!"
}

function _qa_wait_for_files {
  local timeout_seconds="${1:-3}"
  shift
  local -a files=("$@")
  local started_at=$SECONDS

  while true; do
    local all_ready=1
    local candidate
    for candidate in "${files[@]}"; do
      if [[ ! -f "${candidate}" ]]; then
        all_ready=0
        break
      fi
    done

    if [[ "${all_ready}" -eq 1 ]]; then
      return 0
    fi

    if ((SECONDS - started_at >= timeout_seconds)); then
      return 1
    fi

    sleep 0.1
  done
}

function _qa_run_http_matrix_scenario {
  local scenario_id="$1"
  local actor_label="$2"
  local actor_token="$3"
  local conversation_type="$4"
  local conversation_id="$5"
  local message_body="$6"
  local expected_status_csv="$7"
  local history_token="$8"
  local history_conversation_id="$9"
  local ws_token="${10}"
  local ws_topic="${11}"
  local base_url="${12}"
  local ws_base_url="${13}"
  local output_root="${14}"
  local matrix_csv="${15}"
  local guard_ws_token="${16:-}"
  local guard_ws_topic="${17:-}"

  local scenario_dir="${output_root}/${scenario_id}"
  local response_file="${scenario_dir}/response.json"
  local request_file="${scenario_dir}/request.json"
  local before_history_file="${scenario_dir}/history_before.json"
  local after_history_file="${scenario_dir}/history_after.json"
  local ws_log_file="${scenario_dir}/ws_listener.log"
  local ws_ready_file="${scenario_dir}/ws_listener.ready"
  local ws_pid=""
  local guard_ws_log_file="${scenario_dir}/ws_guard.log"
  local guard_ws_ready_file="${scenario_dir}/ws_guard.ready"
  local guard_ws_pid=""
  local ws_wait_seconds="${QA_WS_WAIT_SECONDS:-8}"
  local ws_ready_timeout_seconds="${QA_WS_READY_TIMEOUT_SECONDS:-10}"
  local ws_ready_attempts="${QA_WS_READY_ATTEMPTS:-5}"
  local ws_ready_retry_sleep_seconds="${QA_WS_READY_RETRY_SLEEP_SECONDS:-1}"
  local ws_post_ready_delay_seconds="${QA_WS_POST_READY_DELAY_SECONDS:-0.5}"
  local listener_attempt=1
  local listener_ready="false"
  local guard_listener_attempt=1
  local guard_listener_ready="false"
  local guard_ws_parity="not_checked"

  mkdir -p "${scenario_dir}"

  jq -n \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg body "${message_body}" \
    '{
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      body: $body
    }' > "${request_file}"

  local before_count
  before_count="$(_qa_message_count \
    "${base_url}" \
    "${history_token}" \
    "${history_conversation_id}" \
    "${before_history_file}")"

  if [[ -n "${ws_token}" && -n "${ws_topic}" ]]; then
    rm -f "${ws_ready_file}"

    while ((listener_attempt <= ws_ready_attempts)); do
      _qa_spawn_ws_listener \
        "${ws_base_url}&token=${ws_token}" \
        "${ws_topic}" \
        "${ws_log_file}" \
        "${ws_wait_seconds}" \
        "${ws_ready_file}"
      ws_pid="${_qa_ws_listener_pid}"

      if _qa_wait_for_files "${ws_ready_timeout_seconds}" "${ws_ready_file}"; then
        if [[ -n "${ws_pid}" ]] && ! kill -0 "${ws_pid}" 2>/dev/null; then
          rm -f "${ws_ready_file}"
          ws_pid=""
          listener_attempt=$((listener_attempt + 1))

          if ((listener_attempt <= ws_ready_attempts)); then
            sleep "${ws_ready_retry_sleep_seconds}"
            continue
          fi

          break
        fi

        listener_ready="true"
        break
      fi

      if [[ -n "${ws_pid}" ]]; then
        kill "${ws_pid}" 2>/dev/null || true
        wait "${ws_pid}" || true
        ws_pid=""
      fi

      rm -f "${ws_ready_file}"
      listener_attempt=$((listener_attempt + 1))

      if ((listener_attempt <= ws_ready_attempts)); then
        sleep "${ws_ready_retry_sleep_seconds}"
      fi
    done

    if [[ "${listener_ready}" != "true" ]]; then
      local status="BLOCKED"
      local severity="S2"
      local notes="ws_listener_not_ready_after_${ws_ready_attempts}_attempts"
      local ws_parity="blocked"

      jq -n \
        --arg scenario_id "${scenario_id}" \
        --arg status "${status}" \
        --arg severity "${severity}" \
        --arg actor "${actor_label}" \
        --arg conversation_type "${conversation_type}" \
        --arg conversation_id "${conversation_id}" \
        --arg expected_statuses "${expected_status_csv}" \
        --arg ws_parity "${ws_parity}" \
        --arg guard_ws_parity "${guard_ws_parity}" \
        --arg notes "${notes}" \
        --argjson send_status "-1" \
        --argjson before_count "${before_count}" \
        --argjson after_count "${before_count}" \
        '{
          scenario_id: $scenario_id,
          status: $status,
          severity: $severity,
          actor: $actor,
          conversation_type: $conversation_type,
          conversation_id: $conversation_id,
          expected_statuses: ($expected_statuses | split(",")),
          send_status: $send_status,
          before_count: $before_count,
          after_count: $after_count,
          ws_parity: $ws_parity,
          guard_ws_parity: $guard_ws_parity,
          notes: $notes
        }' > "${scenario_dir}/assert.json"

      printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
        "${scenario_id}" \
        "${status}" \
        "blocked" \
        "${before_count}" \
        "${before_count}" \
        "${ws_parity}" \
        "${severity}" \
        "${notes}" \
        >> "${matrix_csv}"

      return
    fi

    sleep "${ws_post_ready_delay_seconds}"
  fi

  if [[ -n "${guard_ws_token}" && -n "${guard_ws_topic}" ]]; then
    rm -f "${guard_ws_ready_file}"

    while ((guard_listener_attempt <= ws_ready_attempts)); do
      _qa_spawn_ws_listener \
        "${ws_base_url}&token=${guard_ws_token}" \
        "${guard_ws_topic}" \
        "${guard_ws_log_file}" \
        "${ws_wait_seconds}" \
        "${guard_ws_ready_file}"
      guard_ws_pid="${_qa_ws_listener_pid}"

      if _qa_wait_for_files "${ws_ready_timeout_seconds}" "${guard_ws_ready_file}"; then
        if [[ -n "${guard_ws_pid}" ]] && ! kill -0 "${guard_ws_pid}" 2>/dev/null; then
          rm -f "${guard_ws_ready_file}"
          guard_ws_pid=""
          guard_listener_attempt=$((guard_listener_attempt + 1))

          if ((guard_listener_attempt <= ws_ready_attempts)); then
            sleep "${ws_ready_retry_sleep_seconds}"
            continue
          fi

          break
        fi

        guard_listener_ready="true"
        break
      fi

      if [[ -n "${guard_ws_pid}" ]]; then
        kill "${guard_ws_pid}" 2>/dev/null || true
        wait "${guard_ws_pid}" || true
        guard_ws_pid=""
      fi

      rm -f "${guard_ws_ready_file}"
      guard_listener_attempt=$((guard_listener_attempt + 1))

      if ((guard_listener_attempt <= ws_ready_attempts)); then
        sleep "${ws_ready_retry_sleep_seconds}"
      fi
    done

    if [[ "${guard_listener_ready}" != "true" ]]; then
      local status="BLOCKED"
      local severity="S2"
      local notes="ws_guard_listener_not_ready_after_${ws_ready_attempts}_attempts"
      local ws_parity="blocked"
      guard_ws_parity="blocked"

      if [[ -n "${ws_pid}" ]]; then
        kill "${ws_pid}" 2>/dev/null || true
        wait "${ws_pid}" || true
      fi
      if [[ -n "${guard_ws_pid}" ]]; then
        kill "${guard_ws_pid}" 2>/dev/null || true
        wait "${guard_ws_pid}" || true
      fi

      jq -n \
        --arg scenario_id "${scenario_id}" \
        --arg status "${status}" \
        --arg severity "${severity}" \
        --arg actor "${actor_label}" \
        --arg conversation_type "${conversation_type}" \
        --arg conversation_id "${conversation_id}" \
        --arg expected_statuses "${expected_status_csv}" \
        --arg ws_parity "${ws_parity}" \
        --arg guard_ws_parity "${guard_ws_parity}" \
        --arg notes "${notes}" \
        --argjson send_status "-1" \
        --argjson before_count "${before_count}" \
        --argjson after_count "${before_count}" \
        '{
          scenario_id: $scenario_id,
          status: $status,
          severity: $severity,
          actor: $actor,
          conversation_type: $conversation_type,
          conversation_id: $conversation_id,
          expected_statuses: ($expected_statuses | split(",")),
          send_status: $send_status,
          before_count: $before_count,
          after_count: $after_count,
          ws_parity: $ws_parity,
          guard_ws_parity: $guard_ws_parity,
          notes: $notes
        }' > "${scenario_dir}/assert.json"

      printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
        "${scenario_id}" \
        "${status}" \
        "blocked" \
        "${before_count}" \
        "${before_count}" \
        "${ws_parity}" \
        "${severity}" \
        "${notes}" \
        >> "${matrix_csv}"

      return
    fi

    sleep "${ws_post_ready_delay_seconds}"
  fi

  local http_status
  http_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${response_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/v1/conversations/${conversation_id}/messages" \
      -H "Authorization: Bearer ${actor_token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${request_file}" || true
  )"
  if [[ -z "${http_status}" || "${http_status}" == "000" ]]; then
    http_status="-1"
  fi

  if [[ -n "${ws_pid}" ]]; then
    wait "${ws_pid}" || true
  fi
  if [[ -n "${guard_ws_pid}" ]]; then
    wait "${guard_ws_pid}" || true
  fi

  local after_count
  after_count="$(_qa_message_count \
    "${base_url}" \
    "${history_token}" \
    "${history_conversation_id}" \
    "${after_history_file}")"
  local ws_match_token
  ws_match_token="$(_qa_message_match_token "${response_file}" "${message_body}")"

  local expected_delta=0
  if [[ "${expected_status_csv}" == *"201"* ]]; then
    expected_delta=1
  fi

  local status="PASS"
  local severity="none"
  local notes="ok"
  local ws_parity="not_checked"
  local ws_match_token
  ws_match_token="$(_qa_message_match_token "${response_file}" "${message_body}")"

  if ! _qa_status_matches "${http_status}" "${expected_status_csv}"; then
    status="FAIL"
    if [[ "${expected_status_csv}" != *"201"* && "${http_status}" =~ ^20[0-9]$ ]]; then
      severity="S0"
    else
      severity="S1"
    fi
    notes="unexpected_http_status"
  fi

  if [[ "${before_count}" == "-1" || "${after_count}" == "-1" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S2"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="history_count_unavailable"
    else
      notes="${notes};history_count_unavailable"
    fi
  else
    local message_in_after="false"
    if jq -e --arg body "${message_body}" \
      '.data | type == "array" and any(.[]; .content == $body)' \
      "${after_history_file}" >/dev/null 2>&1; then
      message_in_after="true"
    fi

    local delta
    delta=$((after_count - before_count))

    if [[ "${expected_delta}" -eq 1 ]]; then
      if [[ "${delta}" -lt 1 || "${message_in_after}" != "true" ]]; then
        status="FAIL"
        if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
          severity="S1"
        fi

        if [[ "${notes}" == "ok" ]]; then
          notes="persistence_message_missing"
        else
          notes="${notes};persistence_message_missing"
        fi
      elif [[ "${delta}" -gt 1 ]]; then
        status="FAIL"
        if [[ "${severity}" == "none" ]]; then
          severity="S2"
        fi

        if [[ "${notes}" == "ok" ]]; then
          notes="persistence_extra_traffic"
        else
          notes="${notes};persistence_extra_traffic"
        fi
      fi
    elif [[ "${delta}" -ne 0 || "${message_in_after}" == "true" ]]; then
      status="FAIL"
      if [[ "${delta}" -gt 0 || "${message_in_after}" == "true" ]]; then
        severity="S0"
      elif [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
        severity="S1"
      fi

      if [[ "${notes}" == "ok" ]]; then
        notes="persistence_reject_side_effect"
      else
        notes="${notes};persistence_reject_side_effect"
      fi
    fi
  fi

  if [[ -n "${ws_token}" && -n "${ws_topic}" ]]; then
    if [[ -n "${ws_match_token}" ]] &&
      grep -Fq '"new_msg"' "${ws_log_file}" &&
      grep -Fq "${ws_match_token}" "${ws_log_file}"; then
      ws_parity="pass"
    else
      ws_parity="fail"
      status="FAIL"
      if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
        severity="S1"
      fi

      if [[ "${notes}" == "ok" ]]; then
        notes="ws_parity_missing"
      else
        notes="${notes};ws_parity_missing"
      fi
    fi
  fi

  if [[ -n "${guard_ws_token}" && -n "${guard_ws_topic}" ]]; then
    guard_ws_parity="pass"
    if [[ ! -f "${guard_ws_log_file}" ]]; then
      guard_ws_parity="fail"
      status="FAIL"
      if [[ "${severity}" == "none" ]]; then
        severity="S2"
      fi
      if [[ "${notes}" == "ok" ]]; then
        notes="guard_ws_log_missing"
      else
        notes="${notes};guard_ws_log_missing"
      fi
    elif [[ -n "${ws_match_token}" ]] &&
      grep -Fq '"new_msg"' "${guard_ws_log_file}" &&
      grep -Fq "${ws_match_token}" "${guard_ws_log_file}"; then
      guard_ws_parity="fail"
      status="FAIL"
      severity="S0"
      if [[ "${notes}" == "ok" ]]; then
        notes="guard_ws_parity_violation"
      else
        notes="${notes};guard_ws_parity_violation"
      fi
    fi
  fi

  if [[ "${status}" == "FAIL" && "${severity}" == "none" ]]; then
    severity="S1"
  fi

  local send_status_json=0
  if [[ "${http_status}" =~ ^[0-9]+$ ]]; then
    send_status_json="${http_status}"
  fi

  jq -n \
    --arg scenario_id "${scenario_id}" \
    --arg status "${status}" \
    --arg severity "${severity}" \
    --arg actor "${actor_label}" \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg expected_statuses "${expected_status_csv}" \
    --arg ws_parity "${ws_parity}" \
    --arg guard_ws_parity "${guard_ws_parity}" \
    --arg notes "${notes}" \
    --argjson send_status "${send_status_json}" \
    --argjson before_count "${before_count}" \
    --argjson after_count "${after_count}" \
    '{
      scenario_id: $scenario_id,
      status: $status,
      severity: $severity,
      actor: $actor,
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      expected_statuses: ($expected_statuses | split(",")),
      send_status: $send_status,
      before_count: $before_count,
      after_count: $after_count,
      ws_parity: $ws_parity,
      guard_ws_parity: $guard_ws_parity,
      notes: $notes
    }' > "${scenario_dir}/assert.json"

  printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
    "${scenario_id}" \
    "${status}" \
    "${http_status}" \
    "${before_count}" \
    "${after_count}" \
    "${ws_parity}" \
    "${severity}" \
    "${notes}" \
    >> "${matrix_csv}"
}

function _qa_run_revoked_device_scenario {
  local scenario_id="$1"
  local owner_actor_label="$2"
  local owner_actor_token="$3"
  local revoked_actor_label="$4"
  local revoked_actor_token="$5"
  local revoked_device_id="$6"
  local sender_actor_label="$7"
  local sender_actor_token="$8"
  local conversation_type="$9"
  local conversation_id="${10}"
  local ws_topic="${11}"
  local message_body="${12}"
  local history_token="${13}"
  local history_conversation_id="${14}"
  local base_url="${15}"
  local ws_base_url="${16}"
  local output_root="${17}"
  local matrix_csv="${18}"

  local scenario_dir="${output_root}/${scenario_id}"
  local request_file="${scenario_dir}/request.json"
  local response_file="${scenario_dir}/response.json"
  local revoke_request_file="${scenario_dir}/revoke_request.json"
  local revoke_response_file="${scenario_dir}/revoke_response.json"
  local before_history_file="${scenario_dir}/history_before.json"
  local after_history_file="${scenario_dir}/history_after.json"
  local revoked_ws_log_file="${scenario_dir}/ws_revoked.log"
  local revoked_ready_file="${scenario_dir}/ws_revoked.ready"
  local healthy_ws_log_file="${scenario_dir}/ws_healthy.log"
  local healthy_ready_file="${scenario_dir}/ws_healthy.ready"
  local revoked_ws_pid=""
  local healthy_ws_pid=""
  local ws_wait_seconds="${QA_WS_WAIT_SECONDS_R1:-${QA_WS_WAIT_SECONDS:-12}}"
  local ws_ready_timeout_seconds="${QA_WS_READY_TIMEOUT_SECONDS_R1:-${QA_WS_READY_TIMEOUT_SECONDS:-12}}"
  local ws_ready_attempts="${QA_WS_READY_ATTEMPTS_R1:-${QA_WS_READY_ATTEMPTS:-5}}"
  local ws_ready_retry_sleep_seconds="${QA_WS_READY_RETRY_SLEEP_SECONDS:-1}"
  local ws_post_ready_delay_seconds="${QA_WS_POST_READY_DELAY_SECONDS_R1:-${QA_WS_POST_READY_DELAY_SECONDS:-1.5}}"
  local listeners_ready="false"
  local listener_attempt=1

  mkdir -p "${scenario_dir}"

  jq -n \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg body "${message_body}" \
    --arg sender "${sender_actor_label}" \
    '{
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      body: $body,
      sender: $sender
    }' > "${request_file}"

  jq -n \
    --arg actor "${owner_actor_label}" \
    --arg revoked_actor "${revoked_actor_label}" \
    --arg revoked_device_id "${revoked_device_id}" \
    '{
      actor: $actor,
      revoked_actor: $revoked_actor,
      revoked_device_id: $revoked_device_id
    }' > "${revoke_request_file}"

  local before_count
  before_count="$(_qa_message_count \
    "${base_url}" \
    "${history_token}" \
    "${history_conversation_id}" \
    "${before_history_file}")"

  rm -f "${revoked_ready_file}" "${healthy_ready_file}"

  while ((listener_attempt <= ws_ready_attempts)); do
    _qa_spawn_ws_listener \
      "${ws_base_url}&token=${revoked_actor_token}" \
      "${ws_topic}" \
      "${revoked_ws_log_file}" \
      "${ws_wait_seconds}" \
      "${revoked_ready_file}"
    revoked_ws_pid="${_qa_ws_listener_pid}"

    _qa_spawn_ws_listener \
      "${ws_base_url}&token=${sender_actor_token}" \
      "${ws_topic}" \
      "${healthy_ws_log_file}" \
      "${ws_wait_seconds}" \
      "${healthy_ready_file}"
    healthy_ws_pid="${_qa_ws_listener_pid}"

    if _qa_wait_for_files \
      "${ws_ready_timeout_seconds}" \
      "${revoked_ready_file}" \
      "${healthy_ready_file}"; then
      if [[ -n "${revoked_ws_pid}" ]] && ! kill -0 "${revoked_ws_pid}" 2>/dev/null; then
        if [[ -n "${healthy_ws_pid}" ]]; then
          kill "${healthy_ws_pid}" 2>/dev/null || true
          wait "${healthy_ws_pid}" || true
        fi

        rm -f "${revoked_ready_file}" "${healthy_ready_file}"
        revoked_ws_pid=""
        healthy_ws_pid=""
        listener_attempt=$((listener_attempt + 1))

        if ((listener_attempt <= ws_ready_attempts)); then
          sleep "${ws_ready_retry_sleep_seconds}"
          continue
        fi

        break
      fi

      if [[ -n "${healthy_ws_pid}" ]] && ! kill -0 "${healthy_ws_pid}" 2>/dev/null; then
        if [[ -n "${revoked_ws_pid}" ]]; then
          kill "${revoked_ws_pid}" 2>/dev/null || true
          wait "${revoked_ws_pid}" || true
        fi

        rm -f "${revoked_ready_file}" "${healthy_ready_file}"
        revoked_ws_pid=""
        healthy_ws_pid=""
        listener_attempt=$((listener_attempt + 1))

        if ((listener_attempt <= ws_ready_attempts)); then
          sleep "${ws_ready_retry_sleep_seconds}"
          continue
        fi

        break
      fi

      listeners_ready="true"
      break
    fi

    if [[ -n "${revoked_ws_pid}" ]]; then
      kill "${revoked_ws_pid}" 2>/dev/null || true
      wait "${revoked_ws_pid}" || true
      revoked_ws_pid=""
    fi

    if [[ -n "${healthy_ws_pid}" ]]; then
      kill "${healthy_ws_pid}" 2>/dev/null || true
      wait "${healthy_ws_pid}" || true
      healthy_ws_pid=""
    fi

    rm -f "${revoked_ready_file}" "${healthy_ready_file}"
    listener_attempt=$((listener_attempt + 1))

    if ((listener_attempt <= ws_ready_attempts)); then
      sleep "${ws_ready_retry_sleep_seconds}"
    fi
  done

  if [[ "${listeners_ready}" != "true" ]]; then
    local status="BLOCKED"
    local severity="S2"
    local notes="ws_listener_not_ready_after_${ws_ready_attempts}_attempts"
    local ws_parity="blocked"

    jq -n \
      --arg scenario_id "${scenario_id}" \
      --arg status "${status}" \
      --arg severity "${severity}" \
      --arg actor "${sender_actor_label}" \
      --arg conversation_type "${conversation_type}" \
      --arg conversation_id "${conversation_id}" \
      --arg ws_parity "${ws_parity}" \
      --arg notes "${notes}" \
      --arg owner_actor "${owner_actor_label}" \
      --arg revoked_actor "${revoked_actor_label}" \
      --argjson send_status "-1" \
      --argjson revoke_status "-1" \
      --argjson before_count "${before_count}" \
      --argjson after_count "${before_count}" \
      --argjson healthy_has_new_msg "false" \
      --argjson revoked_has_new_msg "false" \
      --argjson revoked_has_security_state "false" \
      '{
        scenario_id: $scenario_id,
        status: $status,
        severity: $severity,
        actor: $actor,
        owner_actor: $owner_actor,
        revoked_actor: $revoked_actor,
        conversation_type: $conversation_type,
        conversation_id: $conversation_id,
        expected_statuses: ["revoke:204", "send:201"],
        send_status: $send_status,
        revoke_status: $revoke_status,
        before_count: $before_count,
        after_count: $after_count,
        ws_parity: $ws_parity,
        healthy_has_new_msg: $healthy_has_new_msg,
        revoked_has_new_msg: $revoked_has_new_msg,
        revoked_has_security_state: $revoked_has_security_state,
        notes: $notes
      }' > "${scenario_dir}/assert.json"

    printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
      "${scenario_id}" \
      "${status}" \
      "blocked" \
      "${before_count}" \
      "${before_count}" \
      "${ws_parity}" \
      "${severity}" \
      "${notes}" \
      >> "${matrix_csv}"

    return
  fi

  sleep "${ws_post_ready_delay_seconds}"

  local revoke_status
  revoke_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${revoke_response_file}" \
      -w "%{http_code}" \
      -X DELETE \
      "${base_url}/api/v1/auth/devices/${revoked_device_id}" \
      -H "Authorization: Bearer ${owner_actor_token}" \
      -H "Content-Type: application/json" || true
  )"
  if [[ -z "${revoke_status}" || "${revoke_status}" == "000" ]]; then
    revoke_status="-1"
  fi

  local send_status
  send_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${response_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/v1/conversations/${conversation_id}/messages" \
      -H "Authorization: Bearer ${sender_actor_token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${request_file}" || true
  )"
  if [[ -z "${send_status}" || "${send_status}" == "000" ]]; then
    send_status="-1"
  fi

  local ws_match_token
  ws_match_token="$(_qa_message_match_token "${response_file}")"

  if [[ -n "${revoked_ws_pid}" ]]; then
    wait "${revoked_ws_pid}" || true
  fi

  if [[ -n "${healthy_ws_pid}" ]]; then
    wait "${healthy_ws_pid}" || true
  fi

  local after_count
  after_count="$(_qa_message_count \
    "${base_url}" \
    "${history_token}" \
    "${history_conversation_id}" \
    "${after_history_file}")"

  local status="PASS"
  local severity="none"
  local notes="ok"
  local ws_parity="pass"

  if [[ "${revoke_status}" != "204" ]]; then
    status="FAIL"
    severity="S1"
    notes="unexpected_revoke_status"
  fi

  if [[ "${send_status}" != "201" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="unexpected_send_status"
    else
      notes="${notes};unexpected_send_status"
    fi
  fi

  if [[ "${before_count}" == "-1" || "${after_count}" == "-1" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S2"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="history_count_unavailable"
    else
      notes="${notes};history_count_unavailable"
    fi
  else
    local delta
    delta=$((after_count - before_count))
    if [[ "${delta}" -ne 1 ]]; then
      status="FAIL"
      if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
        severity="S1"
      fi
      if [[ "${notes}" == "ok" ]]; then
        notes="persistence_delta_mismatch"
      else
        notes="${notes};persistence_delta_mismatch"
      fi
    fi
  fi

  local healthy_has_new_msg="false"
  if [[ -n "${ws_match_token}" ]] &&
    grep -Fq '"new_msg"' "${healthy_ws_log_file}" &&
    grep -Fq "${ws_match_token}" "${healthy_ws_log_file}"; then
    healthy_has_new_msg="true"
  fi

  local revoked_has_new_msg="false"
  if [[ -n "${ws_match_token}" ]] &&
    grep -Fq '"new_msg"' "${revoked_ws_log_file}" &&
    grep -Fq "${ws_match_token}" "${revoked_ws_log_file}"; then
    revoked_has_new_msg="true"
  fi

  local revoked_has_security_state="false"
  if grep -Fq '"security_state"' "${revoked_ws_log_file}" &&
    grep -Fq 'device_revoked' "${revoked_ws_log_file}"; then
    revoked_has_security_state="true"
  fi

  if [[ "${healthy_has_new_msg}" != "true" ]]; then
    status="FAIL"
    ws_parity="fail"
    if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="healthy_ws_missing_new_msg"
    else
      notes="${notes};healthy_ws_missing_new_msg"
    fi
  fi

  if [[ "${revoked_has_new_msg}" == "true" ]]; then
    status="FAIL"
    ws_parity="fail"
    severity="S0"
    if [[ "${notes}" == "ok" ]]; then
      notes="revoked_received_new_msg"
    else
      notes="${notes};revoked_received_new_msg"
    fi
  fi

  if [[ "${revoked_has_security_state}" != "true" ]]; then
    status="FAIL"
    ws_parity="fail"
    if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="revoked_missing_security_state"
    else
      notes="${notes};revoked_missing_security_state"
    fi
  fi

  if [[ "${status}" == "FAIL" && "${severity}" == "none" ]]; then
    severity="S1"
  fi

  local send_status_json=0
  local revoke_status_json=0
  if [[ "${send_status}" =~ ^[0-9]+$ ]]; then
    send_status_json="${send_status}"
  fi
  if [[ "${revoke_status}" =~ ^[0-9]+$ ]]; then
    revoke_status_json="${revoke_status}"
  fi

  jq -n \
    --arg scenario_id "${scenario_id}" \
    --arg status "${status}" \
    --arg severity "${severity}" \
    --arg actor "${sender_actor_label}" \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg ws_parity "${ws_parity}" \
    --arg notes "${notes}" \
    --arg owner_actor "${owner_actor_label}" \
    --arg revoked_actor "${revoked_actor_label}" \
    --argjson send_status "${send_status_json}" \
    --argjson revoke_status "${revoke_status_json}" \
    --argjson before_count "${before_count}" \
    --argjson after_count "${after_count}" \
    --argjson healthy_has_new_msg "$([[ "${healthy_has_new_msg}" == "true" ]] && echo "true" || echo "false")" \
    --argjson revoked_has_new_msg "$([[ "${revoked_has_new_msg}" == "true" ]] && echo "true" || echo "false")" \
    --argjson revoked_has_security_state "$([[ "${revoked_has_security_state}" == "true" ]] && echo "true" || echo "false")" \
    '{
      scenario_id: $scenario_id,
      status: $status,
      severity: $severity,
      actor: $actor,
      owner_actor: $owner_actor,
      revoked_actor: $revoked_actor,
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      expected_statuses: ["revoke:204", "send:201"],
      send_status: $send_status,
      revoke_status: $revoke_status,
      before_count: $before_count,
      after_count: $after_count,
      ws_parity: $ws_parity,
      healthy_has_new_msg: $healthy_has_new_msg,
      revoked_has_new_msg: $revoked_has_new_msg,
      revoked_has_security_state: $revoked_has_security_state,
      notes: $notes
    }' > "${scenario_dir}/assert.json"

  printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
    "${scenario_id}" \
    "${status}" \
    "${send_status}" \
    "${before_count}" \
    "${after_count}" \
    "${ws_parity}" \
    "${severity}" \
    "${notes};revoke_status=${revoke_status}" \
    >> "${matrix_csv}"
}

function _qa_run_recovery_rejoin_scenario {
  local scenario_id="$1"
  local actor_label="$2"
  local actor_token="$3"
  local observer_label="$4"
  local observer_token="$5"
  local conversation_type="$6"
  local conversation_id="$7"
  local ws_topic="$8"
  local message_body="$9"
  local history_token="${10}"
  local history_conversation_id="${11}"
  local base_url="${12}"
  local ws_base_url="${13}"
  local output_root="${14}"
  local matrix_csv="${15}"

  local scenario_dir="${output_root}/${scenario_id}"
  local reset_request_file="${scenario_dir}/reset_request.json"
  local reset_response_file="${scenario_dir}/reset_response.json"
  local recover_request_file="${scenario_dir}/recover_request.json"
  local recover_response_file="${scenario_dir}/recover_response.json"
  local recover_replay_response_file="${scenario_dir}/recover_replay_response.json"
  local send_request_file="${scenario_dir}/request.json"
  local send_response_file="${scenario_dir}/response.json"
  local before_history_file="${scenario_dir}/history_before.json"
  local after_history_file="${scenario_dir}/history_after.json"
  local ws_log_file="${scenario_dir}/ws_${observer_label}.log"
  local ws_ready_file="${scenario_dir}/ws_${observer_label}.ready"
  local ws_pid=""

  local ws_wait_seconds="${QA_WS_WAIT_SECONDS_R2:-${QA_WS_WAIT_SECONDS:-10}}"
  local ws_ready_timeout_seconds="${QA_WS_READY_TIMEOUT_SECONDS_R2:-${QA_WS_READY_TIMEOUT_SECONDS:-12}}"
  local ws_ready_attempts="${QA_WS_READY_ATTEMPTS_R2:-${QA_WS_READY_ATTEMPTS:-5}}"
  local ws_ready_retry_sleep_seconds="${QA_WS_READY_RETRY_SLEEP_SECONDS:-1}"
  local ws_post_ready_delay_seconds="${QA_WS_POST_READY_DELAY_SECONDS_R2:-${QA_WS_POST_READY_DELAY_SECONDS:-1}}"
  local listener_attempt=1
  local listener_ready="false"

  mkdir -p "${scenario_dir}"

  local recovery_ref
  recovery_ref="qa-${scenario_id}-$(date -u +%Y%m%dT%H%M%S)"
  local rejoin_token="qa-${scenario_id}-rejoin"

  jq -n \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    '{
      conversation_type: $conversation_type,
      conversation_id: $conversation_id
    }' > "${reset_request_file}"

  jq -n \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg recovery_ref "${recovery_ref}" \
    --arg rejoin_token "${rejoin_token}" \
    --arg recovery_reason "qa_matrix_rejoin" \
    '{
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      recovery_ref: $recovery_ref,
      rejoin_token: $rejoin_token,
      recovery_reason: $recovery_reason
    }' > "${recover_request_file}"

  jq -n \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg body "${message_body}" \
    --arg sender "${actor_label}" \
    '{
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      body: $body,
      sender: $sender
    }' > "${send_request_file}"

  local before_count
  before_count="$(_qa_message_count \
    "${base_url}" \
    "${history_token}" \
    "${history_conversation_id}" \
    "${before_history_file}")"

  local reset_status
  reset_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${reset_response_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/test/conversation_security/reset_state" \
      -H "Authorization: Bearer ${actor_token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${reset_request_file}" || true
  )"
  if [[ -z "${reset_status}" || "${reset_status}" == "000" ]]; then
    reset_status="-1"
  fi

  local recover_status
  recover_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${recover_response_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/v1/conversations/${conversation_id}/security/recover" \
      -H "Authorization: Bearer ${actor_token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${recover_request_file}" || true
  )"
  if [[ -z "${recover_status}" || "${recover_status}" == "000" ]]; then
    recover_status="-1"
  fi

  local recover_replay_status
  recover_replay_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${recover_replay_response_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/v1/conversations/${conversation_id}/security/recover" \
      -H "Authorization: Bearer ${actor_token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${recover_request_file}" || true
  )"
  if [[ -z "${recover_replay_status}" || "${recover_replay_status}" == "000" ]]; then
    recover_replay_status="-1"
  fi

  rm -f "${ws_ready_file}"

  while ((listener_attempt <= ws_ready_attempts)); do
    _qa_spawn_ws_listener \
      "${ws_base_url}&token=${observer_token}" \
      "${ws_topic}" \
      "${ws_log_file}" \
      "${ws_wait_seconds}" \
      "${ws_ready_file}"
    ws_pid="${_qa_ws_listener_pid}"

    if _qa_wait_for_files "${ws_ready_timeout_seconds}" "${ws_ready_file}"; then
      if [[ -n "${ws_pid}" ]] && ! kill -0 "${ws_pid}" 2>/dev/null; then
        rm -f "${ws_ready_file}"
        ws_pid=""
        listener_attempt=$((listener_attempt + 1))

        if ((listener_attempt <= ws_ready_attempts)); then
          sleep "${ws_ready_retry_sleep_seconds}"
          continue
        fi

        break
      fi

      listener_ready="true"
      break
    fi

    if [[ -n "${ws_pid}" ]]; then
      kill "${ws_pid}" 2>/dev/null || true
      wait "${ws_pid}" || true
      ws_pid=""
    fi

    rm -f "${ws_ready_file}"
    listener_attempt=$((listener_attempt + 1))

    if ((listener_attempt <= ws_ready_attempts)); then
      sleep "${ws_ready_retry_sleep_seconds}"
    fi
  done

  if [[ "${listener_ready}" != "true" ]]; then
    local status="BLOCKED"
    local severity="S2"
    local notes="ws_listener_not_ready_after_${ws_ready_attempts}_attempts"
    local ws_parity="blocked"
    local reset_status_json=0
    local recover_status_json=0
    local recover_replay_status_json=0

    if [[ "${reset_status}" =~ ^[0-9]+$ ]]; then
      reset_status_json="${reset_status}"
    fi
    if [[ "${recover_status}" =~ ^[0-9]+$ ]]; then
      recover_status_json="${recover_status}"
    fi
    if [[ "${recover_replay_status}" =~ ^[0-9]+$ ]]; then
      recover_replay_status_json="${recover_replay_status}"
    fi

    jq -n \
      --arg scenario_id "${scenario_id}" \
      --arg status "${status}" \
      --arg severity "${severity}" \
      --arg actor "${actor_label}" \
      --arg observer_actor "${observer_label}" \
      --arg conversation_type "${conversation_type}" \
      --arg conversation_id "${conversation_id}" \
      --arg ws_parity "${ws_parity}" \
      --arg notes "${notes}" \
      --argjson reset_status "${reset_status_json}" \
      --argjson recover_status "${recover_status_json}" \
      --argjson recover_replay_status "${recover_replay_status_json}" \
      --argjson send_status "-1" \
      --argjson before_count "${before_count}" \
      --argjson after_count "${before_count}" \
      --argjson replay_idempotent "false" \
      --argjson observer_has_new_msg "false" \
      '{
        scenario_id: $scenario_id,
        status: $status,
        severity: $severity,
        actor: $actor,
        observer_actor: $observer_actor,
        conversation_type: $conversation_type,
        conversation_id: $conversation_id,
        expected_statuses: ["reset:200", "recover:200", "recover_replay:200", "send_after_recover:201"],
        reset_status: $reset_status,
        recover_status: $recover_status,
        recover_replay_status: $recover_replay_status,
        send_status: $send_status,
        before_count: $before_count,
        after_count: $after_count,
        ws_parity: $ws_parity,
        replay_idempotent: $replay_idempotent,
        observer_has_new_msg: $observer_has_new_msg,
        notes: $notes
      }' > "${scenario_dir}/assert.json"

    printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
      "${scenario_id}" \
      "${status}" \
      "blocked" \
      "${before_count}" \
      "${before_count}" \
      "${ws_parity}" \
      "${severity}" \
      "${notes};reset_status=${reset_status};recover_status=${recover_status};replay_status=${recover_replay_status}" \
      >> "${matrix_csv}"

    return
  fi

  sleep "${ws_post_ready_delay_seconds}"

  local send_status
  send_status="$(
    curl -sS \
      --connect-timeout "${QA_CURL_CONNECT_TIMEOUT_SECONDS:-3}" \
      --max-time "${QA_CURL_MAX_TIME_SECONDS:-12}" \
      -o "${send_response_file}" \
      -w "%{http_code}" \
      -X POST \
      "${base_url}/api/v1/conversations/${conversation_id}/messages" \
      -H "Authorization: Bearer ${actor_token}" \
      -H "Content-Type: application/json" \
      --data-binary "@${send_request_file}" || true
  )"
  if [[ -z "${send_status}" || "${send_status}" == "000" ]]; then
    send_status="-1"
  fi

  if [[ -n "${ws_pid}" ]]; then
    wait "${ws_pid}" || true
  fi

  local after_count
  after_count="$(_qa_message_count \
    "${base_url}" \
    "${history_token}" \
    "${history_conversation_id}" \
    "${after_history_file}")"

  local replay_idempotent="false"
  if jq -e '.data.idempotent == true or .idempotent == true' "${recover_replay_response_file}" >/dev/null 2>&1; then
    replay_idempotent="true"
  fi

  local ws_match_token
  ws_match_token="$(_qa_message_match_token "${send_response_file}")"

  local observer_has_new_msg="false"
  if [[ -n "${ws_match_token}" ]] &&
    grep -Fq '"new_msg"' "${ws_log_file}" &&
    grep -Fq "${ws_match_token}" "${ws_log_file}"; then
    observer_has_new_msg="true"
  fi

  local status="PASS"
  local severity="none"
  local notes="ok"
  local ws_parity="pass"

  if [[ "${reset_status}" != "200" ]]; then
    status="FAIL"
    severity="S1"
    notes="unexpected_reset_status"
  fi

  if [[ "${recover_status}" != "200" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="unexpected_recover_status"
    else
      notes="${notes};unexpected_recover_status"
    fi
  fi

  if [[ "${recover_replay_status}" != "200" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="unexpected_recover_replay_status"
    else
      notes="${notes};unexpected_recover_replay_status"
    fi
  fi

  if [[ "${replay_idempotent}" != "true" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="recover_replay_not_idempotent"
    else
      notes="${notes};recover_replay_not_idempotent"
    fi
  fi

  if [[ "${send_status}" != "201" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="unexpected_send_status"
    else
      notes="${notes};unexpected_send_status"
    fi
  fi

  if [[ "${before_count}" == "-1" || "${after_count}" == "-1" ]]; then
    status="FAIL"
    if [[ "${severity}" == "none" ]]; then
      severity="S2"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="history_count_unavailable"
    else
      notes="${notes};history_count_unavailable"
    fi
  else
    local delta
    delta=$((after_count - before_count))
    if [[ "${delta}" -ne 1 ]]; then
      status="FAIL"
      if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
        severity="S1"
      fi
      if [[ "${notes}" == "ok" ]]; then
        notes="persistence_delta_mismatch"
      else
        notes="${notes};persistence_delta_mismatch"
      fi
    fi
  fi

  if [[ "${observer_has_new_msg}" != "true" ]]; then
    status="FAIL"
    ws_parity="fail"
    if [[ "${severity}" == "none" || "${severity}" == "S2" ]]; then
      severity="S1"
    fi
    if [[ "${notes}" == "ok" ]]; then
      notes="observer_ws_missing_new_msg"
    else
      notes="${notes};observer_ws_missing_new_msg"
    fi
  fi

  local reset_status_json=0
  local recover_status_json=0
  local recover_replay_status_json=0
  local send_status_json=0
  if [[ "${reset_status}" =~ ^[0-9]+$ ]]; then
    reset_status_json="${reset_status}"
  fi
  if [[ "${recover_status}" =~ ^[0-9]+$ ]]; then
    recover_status_json="${recover_status}"
  fi
  if [[ "${recover_replay_status}" =~ ^[0-9]+$ ]]; then
    recover_replay_status_json="${recover_replay_status}"
  fi
  if [[ "${send_status}" =~ ^[0-9]+$ ]]; then
    send_status_json="${send_status}"
  fi

  jq -n \
    --arg scenario_id "${scenario_id}" \
    --arg status "${status}" \
    --arg severity "${severity}" \
    --arg actor "${actor_label}" \
    --arg observer_actor "${observer_label}" \
    --arg conversation_type "${conversation_type}" \
    --arg conversation_id "${conversation_id}" \
    --arg ws_parity "${ws_parity}" \
    --arg notes "${notes}" \
    --argjson reset_status "${reset_status_json}" \
    --argjson recover_status "${recover_status_json}" \
    --argjson recover_replay_status "${recover_replay_status_json}" \
    --argjson send_status "${send_status_json}" \
    --argjson before_count "${before_count}" \
    --argjson after_count "${after_count}" \
    --argjson replay_idempotent "$([[ "${replay_idempotent}" == "true" ]] && echo "true" || echo "false")" \
    --argjson observer_has_new_msg "$([[ "${observer_has_new_msg}" == "true" ]] && echo "true" || echo "false")" \
    '{
      scenario_id: $scenario_id,
      status: $status,
      severity: $severity,
      actor: $actor,
      observer_actor: $observer_actor,
      conversation_type: $conversation_type,
      conversation_id: $conversation_id,
      expected_statuses: ["reset:200", "recover:200", "recover_replay:200", "send_after_recover:201"],
      reset_status: $reset_status,
      recover_status: $recover_status,
      recover_replay_status: $recover_replay_status,
      send_status: $send_status,
      before_count: $before_count,
      after_count: $after_count,
      ws_parity: $ws_parity,
      replay_idempotent: $replay_idempotent,
      observer_has_new_msg: $observer_has_new_msg,
      notes: $notes
    }' > "${scenario_dir}/assert.json"

  printf '%s,%s,%s,%s,%s,%s,%s,"%s"\n' \
    "${scenario_id}" \
    "${status}" \
    "${send_status}" \
    "${before_count}" \
    "${after_count}" \
    "${ws_parity}" \
    "${severity}" \
    "${notes};reset_status=${reset_status};recover_status=${recover_status};replay_status=${recover_replay_status}" \
    >> "${matrix_csv}"
}

function _qa_array_to_json {
  if [[ "$#" -eq 0 ]]; then
    echo "[]"
    return
  fi

  printf '%s\n' "$@" | jq -R . | jq -s .
}

function _qa_compose_ps_safe {
  if timeout 15 docker compose ps; then
    return 0
  fi

  echo "Warning: docker compose ps timed out; falling back to docker ps." >&2
  docker ps \
    --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}'
}

function _qa_acquire_run_lock {
  local lock_dir="$1"
  local stale_seconds="${QA_RUN_LOCK_STALE_SECONDS:-120}"
  mkdir -p "$(dirname "${lock_dir}")"

  if mkdir "${lock_dir}" 2>/dev/null; then
    printf '%s\n' "$$" > "${lock_dir}/pid"
    _qa_active_run_lock_dir="${lock_dir}"
    return 0
  fi

  local existing_pid
  existing_pid="$(cat "${lock_dir}/pid" 2>/dev/null || true)"

  if [[ -z "${existing_pid}" ]]; then
    local now_epoch
    now_epoch="$(date +%s)"
    local lock_epoch
    lock_epoch="$(stat -c %Y "${lock_dir}" 2>/dev/null || echo "${now_epoch}")"
    local lock_age=$((now_epoch - lock_epoch))

    # A lock without pid is likely in-flight acquisition. Treat as active unless stale.
    if ((lock_age < stale_seconds)); then
      return 1
    fi
  fi

  if [[ -n "${existing_pid}" && "${existing_pid}" =~ ^[0-9]+$ ]] &&
    kill -0 "${existing_pid}" 2>/dev/null; then
    return 1
  fi

  rm -rf "${lock_dir}" 2>/dev/null || true

  if mkdir "${lock_dir}" 2>/dev/null; then
    printf '%s\n' "$$" > "${lock_dir}/pid"
    _qa_active_run_lock_dir="${lock_dir}"
    return 0
  fi

  return 1
}

function _qa_release_run_lock {
  if [[ -n "${_qa_active_run_lock_dir:-}" ]]; then
    rm -rf "${_qa_active_run_lock_dir}" 2>/dev/null || true
    unset _qa_active_run_lock_dir
  fi
}

function qa:messaging:preflight {
  # Validate runtime prerequisites before live messaging QA probes.
  local output_dir="${1:-}"
  local log_file=""

  if [[ -n "${output_dir}" ]]; then
    mkdir -p "${output_dir}"
    log_file="${output_dir}/preflight.log"
  fi

  _qa_require_host_command jq "Install jq." || return 1
  _qa_require_host_command curl "Install curl." || return 1
  _qa_require_host_command node "Install Node.js for WS probe parity." || return 1

  if [[ -n "${log_file}" ]]; then
    {
      echo "timestamp_utc=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo "cwd=$(pwd)"
      echo "docker_compose_ps_start"
      _qa_compose_ps_safe
      echo "docker_compose_ps_end"
    } | tee "${log_file}"
  else
    echo "timestamp_utc=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "cwd=$(pwd)"
    _qa_compose_ps_safe
  fi

  if [[ -n "${log_file}" ]]; then
    echo "migration_check_start" | tee -a "${log_file}"
    if ! cmd mix ecto.migrations >> "${log_file}" 2>&1; then
      echo "Migration preflight failed (unable to read migration status)." >&2
      return 1
    fi
    if grep -Eq '^[[:space:]]*down[[:space:]]' "${log_file}"; then
      echo "Migration preflight failed (pending/failed migrations). QA run blocked." >&2
      return 1
    fi
    echo "migration_check_end" | tee -a "${log_file}"
  else
    local migration_output
    migration_output="$(cmd mix ecto.migrations)" || {
      echo "Migration preflight failed (unable to read migration status)." >&2
      return 1
    }
    if printf '%s\n' "${migration_output}" | grep -Eq '^[[:space:]]*down[[:space:]]'; then
      echo "Migration preflight failed (pending/failed migrations). QA run blocked." >&2
      return 1
    fi
  fi
}

function _qa_messaging_run {
  local mode="$1"
  shift

  local project_root
  project_root="$(_qa_project_root)"

  local run_id_base="${QA_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)}"
  local run_id="${run_id_base}"
  local output_root=""

  if [[ -z "${QA_RUN_ID:-}" ]]; then
    run_id="${run_id_base}_${mode}"
  fi

  output_root="${project_root}/.tmp/_qa_messaging/${run_id}"

  if [[ -z "${QA_RUN_ID:-}" ]]; then
    local attempt=1
    while [[ -e "${output_root}" ]]; do
      run_id="${run_id_base}_${mode}_${attempt}"
      output_root="${project_root}/.tmp/_qa_messaging/${run_id}"
      attempt=$((attempt + 1))
    done
  fi

  local base_url
  base_url="$(_qa_base_url)"
  local ws_base_url
  ws_base_url="$(_qa_ws_base_url "${base_url}")"

  local matrix_csv="${output_root}/matrix_results.csv"
  local summary_file="${output_root}/summary.md"
  local gate_report="${output_root}/gate_report.json"
  local run_lock_dir="${project_root}/.tmp/_qa_messaging/.active_run_lock"

  if ! _qa_acquire_run_lock "${run_lock_dir}"; then
    local blocked_output_root="${project_root}/.tmp/_qa_messaging/${run_id}_blocked_$$"
    local blocked_attempt=1
    while [[ -e "${blocked_output_root}" ]]; do
      blocked_output_root="${project_root}/.tmp/_qa_messaging/${run_id}_blocked_${$}_${blocked_attempt}"
      blocked_attempt=$((blocked_attempt + 1))
    done
    local blocked_gate_report="${blocked_output_root}/gate_report.json"
    mkdir -p "${blocked_output_root}"
    jq -n \
      --arg run_id "${run_id}" \
      --arg mode "${mode}" \
      --arg started_at "${started_at:-$(date -u +%Y-%m-%dT%H:%M:%SZ)}" \
      --arg ended_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --arg outcome "BLOCKED" \
      --arg reason "qa_run_already_active" \
      '{
        run_id: $run_id,
        mode: $mode,
        started_at: $started_at,
        ended_at: $ended_at,
        outcome: $outcome,
        reason: $reason
      }' > "${blocked_gate_report}"
    return 2
  fi
  mkdir -p "${output_root}"
  printf 'scenario_id,status,http_status,before_count,after_count,ws_parity,severity,notes\n' > "${matrix_csv}"

  local started_at
  started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  if ! qa:messaging:preflight "${output_root}"; then
    jq -n \
      --arg run_id "${run_id}" \
      --arg mode "${mode}" \
      --arg started_at "${started_at}" \
      --arg ended_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --arg outcome "BLOCKED" \
      --arg reason "preflight_failed" \
      '{
        run_id: $run_id,
        mode: $mode,
        started_at: $started_at,
        ended_at: $ended_at,
        outcome: $outcome,
        reason: $reason
      }' > "${gate_report}"
    _qa_release_run_lock
    return 2
  fi

  local run_id_slug
  run_id_slug="$(
    printf '%s' "${run_id}" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9'
  )"

  if ! runbook:seed:matrix \
    --family-name "Runbook Family ${run_id_slug}" \
    --outsider-family-name "Runbook Outsider Family ${run_id_slug}" \
    --sender-username "runbook_sender_${run_id_slug}" \
    --receiver-username "runbook_receiver_${run_id_slug}" \
    --third-username "runbook_member_${run_id_slug}" \
    --outsider-username "runbook_outsider_${run_id_slug}" \
    --group-name "Runbook Group ${run_id_slug}" \
    "$@" | sed -n '/^{/,$p' > "${output_root}/seed_matrix.json"; then
    jq -n \
      --arg run_id "${run_id}" \
      --arg mode "${mode}" \
      --arg started_at "${started_at}" \
      --arg ended_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --arg outcome "BLOCKED" \
      --arg reason "seed_failed" \
      '{
        run_id: $run_id,
        mode: $mode,
        started_at: $started_at,
        ended_at: $ended_at,
        outcome: $outcome,
        reason: $reason
      }' > "${gate_report}"
    _qa_release_run_lock
    return 2
  fi

  local seed_file="${output_root}/seed_matrix.json"

  local a_tab1_token
  local a_tab2_token
  local a_dev2_token
  local a_dev2_device_id
  local b_token
  local c_token
  local outsider_token
  local self_sender_id
  local self_receiver_id
  local direct_id
  local group_id
  local family_id
  local direct_topic
  local group_topic
  local family_topic
  local self_sender_topic
  local self_receiver_topic

  a_tab1_token="$(jq -r '.actors.a_tab1.access_token' "${seed_file}")"
  a_tab2_token="$(jq -r '.actors.a_tab2.access_token' "${seed_file}")"
  a_dev2_token="$(jq -r '.actors.a_dev2.access_token' "${seed_file}")"
  a_dev2_device_id="$(jq -r '.actors.a_dev2.device_id' "${seed_file}")"
  b_token="$(jq -r '.actors.b.access_token' "${seed_file}")"
  c_token="$(jq -r '.actors.c.access_token' "${seed_file}")"
  outsider_token="$(jq -r '.actors.outsider.access_token' "${seed_file}")"
  self_sender_id="$(jq -r '.conversations.self_sender.id' "${seed_file}")"
  self_receiver_id="$(jq -r '.conversations.self_receiver.id' "${seed_file}")"
  direct_id="$(jq -r '.conversations.direct.id' "${seed_file}")"
  group_id="$(jq -r '.conversations.group.id' "${seed_file}")"
  family_id="$(jq -r '.conversations.family.id' "${seed_file}")"
  direct_topic="$(jq -r '.conversations.direct.topic' "${seed_file}")"
  group_topic="$(jq -r '.conversations.group.topic' "${seed_file}")"
  family_topic="$(jq -r '.conversations.family.topic' "${seed_file}")"
  self_sender_topic="$(jq -r '.conversations.self_sender.topic' "${seed_file}")"
  self_receiver_topic="$(jq -r '.conversations.self_receiver.topic' "${seed_file}")"

  local -a required_fields=(
    "${a_tab1_token}"
    "${a_tab2_token}"
    "${a_dev2_token}"
    "${a_dev2_device_id}"
    "${b_token}"
    "${c_token}"
    "${outsider_token}"
    "${self_sender_id}"
    "${self_receiver_id}"
    "${direct_id}"
    "${group_id}"
    "${family_id}"
    "${self_sender_topic}"
    "${self_receiver_topic}"
    "${direct_topic}"
    "${group_topic}"
    "${family_topic}"
  )

  local field
  for field in "${required_fields[@]}"; do
    if [[ -z "${field}" || "${field}" == "null" ]]; then
      jq -n \
        --arg run_id "${run_id}" \
        --arg mode "${mode}" \
        --arg started_at "${started_at}" \
        --arg ended_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --arg outcome "BLOCKED" \
        --arg reason "seed_payload_incomplete" \
        '{
          run_id: $run_id,
          mode: $mode,
          started_at: $started_at,
          ended_at: $ended_at,
          outcome: $outcome,
          reason: $reason
        }' > "${gate_report}"
      _qa_release_run_lock
      return 2
    fi
  done

  local preseed_dir="${output_root}/preseed_recovery"
  mkdir -p "${preseed_dir}"

  local preseed_self_sender_status
  local preseed_self_receiver_status
  local preseed_direct_status
  local preseed_group_status
  local preseed_family_status

  preseed_self_sender_status="$(_qa_recover_conversation_state \
    "${base_url}" \
    "${a_tab1_token}" \
    "${self_sender_id}" \
    "qa-${run_id}-self-sender" \
    "${preseed_dir}/self_sender.response.json")"

  preseed_self_receiver_status="$(_qa_recover_conversation_state \
    "${base_url}" \
    "${b_token}" \
    "${self_receiver_id}" \
    "qa-${run_id}-self-receiver" \
    "${preseed_dir}/self_receiver.response.json")"

  preseed_direct_status="$(_qa_recover_conversation_state \
    "${base_url}" \
    "${a_tab1_token}" \
    "${direct_id}" \
    "qa-${run_id}-direct" \
    "${preseed_dir}/direct.response.json")"

  preseed_group_status="$(_qa_recover_conversation_state \
    "${base_url}" \
    "${a_tab1_token}" \
    "${group_id}" \
    "qa-${run_id}-group" \
    "${preseed_dir}/group.response.json")"

  preseed_family_status="$(_qa_recover_conversation_state \
    "${base_url}" \
    "${a_tab1_token}" \
    "${family_id}" \
    "qa-${run_id}-family" \
    "${preseed_dir}/family.response.json")"

  if [[ "${preseed_self_sender_status}" != "200" ||
    "${preseed_self_receiver_status}" != "200" ||
    "${preseed_direct_status}" != "200" ||
    "${preseed_group_status}" != "200" ||
    "${preseed_family_status}" != "200" ]]; then
    jq -n \
      --arg run_id "${run_id}" \
      --arg mode "${mode}" \
      --arg started_at "${started_at}" \
      --arg ended_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --arg outcome "BLOCKED" \
      --arg reason "preseed_recovery_failed" \
      --argjson self_sender_status "${preseed_self_sender_status}" \
      --argjson self_receiver_status "${preseed_self_receiver_status}" \
      --argjson direct_status "${preseed_direct_status}" \
      --argjson group_status "${preseed_group_status}" \
      --argjson family_status "${preseed_family_status}" \
      '{
        run_id: $run_id,
        mode: $mode,
        started_at: $started_at,
        ended_at: $ended_at,
        outcome: $outcome,
        reason: $reason,
        preseed_recovery_statuses: {
          self_sender: $self_sender_status,
          self_receiver: $self_receiver_status,
          direct: $direct_status,
          group: $group_status,
          family: $family_status
        }
      }' > "${gate_report}"
    _qa_release_run_lock
    return 2
  fi

  local canonical_status="PASS"
  local canonical_elapsed=0
  SECONDS=0
  # shellcheck disable=SC2119
  if ! elixir:test:canonical-flow > "${output_root}/canonical_flow_result.txt" 2>&1; then
    canonical_status="FAIL"
  fi
  canonical_elapsed="${SECONDS}"
  printf 'elapsed_seconds=%s\n' "${canonical_elapsed}" > "${output_root}/canonical_flow_timing.txt"

  local coverage_status="SKIP"
  local continuity_contract_status="PASS"
  local recovery_contract_status="SKIP"

  if ! elixir:test test/famichat_web/integration/messaging_gap_contract_test.exs \
    > "${output_root}/continuity_contract.txt" 2>&1; then
    continuity_contract_status="FAIL"
  fi

  if [[ "${mode}" == "deep" ]]; then
    coverage_status="PASS"
    if ! elixir:test:coverage test/famichat_web/integration/canonical_messaging_flow_test.exs \
      > "${output_root}/canonical_flow_coverage.txt" 2>&1; then
      coverage_status="FAIL"
    fi

    recovery_contract_status="PASS"
    if ! elixir:test test/famichat_web/integration/recovery_rejoin_security_flow_test.exs \
      > "${output_root}/recovery_rejoin_contract.txt" 2>&1; then
      recovery_contract_status="FAIL"
    fi
  fi

  # ---------------------------------------------------------------------------
  # G1 — MLS failure-rate gate
  # Scans canonical_flow_result.txt and continuity_contract.txt for MLS
  # failure telemetry log lines emitted by MessageService.emit_mls_failure/5.
  # Gate passes when mls_failure_rate < 0.05 (5%).
  # Format: mls_failures / (mls_attempts + mls_failures) where attempts =
  # total messages attempted (approximated from matrix send count in logs).
  # In test mode the NIF is stubbed so failures appear only on real errors.
  # ---------------------------------------------------------------------------
  local mls_failure_rate
  local mls_failure_gate
  local mls_failure_count=0
  local mls_total_count=0

  # Count explicit MLS failure telemetry lines across all canonical output
  local _g1_scan_files=()
  [[ -f "${output_root}/canonical_flow_result.txt" ]] && \
    _g1_scan_files+=("${output_root}/canonical_flow_result.txt")
  [[ -f "${output_root}/continuity_contract.txt" ]] && \
    _g1_scan_files+=("${output_root}/continuity_contract.txt")
  [[ -f "${output_root}/canonical_flow_coverage.txt" ]] && \
    _g1_scan_files+=("${output_root}/canonical_flow_coverage.txt")

  if [[ "${#_g1_scan_files[@]}" -gt 0 ]]; then
    # grep -c with multiple files prints "file:count"; sum the counts via awk
    mls_failure_count=$(
      {
        grep -h -c '\[Telemetry\].*famichat.*message.*mls_failure\|mls_encryption_failed\|mls_decryption_failed' \
          "${_g1_scan_files[@]}" 2>/dev/null || true
      } | awk -F: '{ s += $NF } END { print s+0 }'
    )
    # Total attempts: mls failures + successful sends observed in matrix CSV
    local _mls_sends
    _mls_sends=$(grep -c ',PASS,' "${output_root}/matrix_results.csv" 2>/dev/null || true)
    _mls_sends=$(printf '%s\n' "${_mls_sends:-0}" | tail -n1)
    mls_total_count=$(( mls_failure_count + _mls_sends ))
  fi

  if [[ "${mls_total_count}" -eq 0 ]]; then
    # No sends observed yet; treat rate as 0.0 (cannot divide by zero)
    mls_failure_rate="0.0"
    mls_failure_gate="PASS"
  else
    # Use awk for floating-point division
    mls_failure_rate=$(awk "BEGIN { printf \"%.4f\", ${mls_failure_count} / ${mls_total_count} }")
    mls_failure_gate=$(awk "BEGIN { print (${mls_failure_rate} < 0.05) ? \"PASS\" : \"FAIL\" }")
  fi

  # ---------------------------------------------------------------------------
  # G2 — Coverage snapshot gate
  # Parses [TOTAL] line from canonical_flow_coverage.txt produced by
  # elixir:test:coverage during deep runs. Gate passes when >= 80.0%.
  # In fast/non-deep runs the coverage file is absent; gate is SKIP.
  # ---------------------------------------------------------------------------
  local coverage_snapshot_pct="null"
  local coverage_snapshot_gate="SKIP"

  if [[ -f "${output_root}/canonical_flow_coverage.txt" ]]; then
    local _raw_pct
    _raw_pct=$(grep '^\[TOTAL\]' "${output_root}/canonical_flow_coverage.txt" \
      | grep -oP '[0-9]+\.[0-9]+' | head -1 || true)
    if [[ -n "${_raw_pct}" ]]; then
      coverage_snapshot_pct="${_raw_pct}"
      coverage_snapshot_gate=$(awk "BEGIN { print (${_raw_pct} >= 80.0) ? \"PASS\" : \"FAIL\" }")
    fi
  fi

  # ---------------------------------------------------------------------------
  # G3 — Per-operation timing budget gate
  # Reads canonical_flow_timing_detail.json written by the Day 2 timing test
  # in canonical_messaging_flow_test.exs during elixir:test:canonical-flow.
  # Gate passes when every per-operation field is < 200ms.
  # Gate is SKIP when the file is absent (canonical flow not run or fast mode
  # without timing test).  Gate is FAIL (hard gate) when any field >= 200ms.
  # ---------------------------------------------------------------------------
  local timing_detail_file="${project_root}/backend/.tmp/canonical_flow_timing_detail.json"
  local timing_budget_gate="SKIP"
  local timing_detail_json="null"

  if [[ -f "${timing_detail_file}" ]]; then
    timing_detail_json="$(cat "${timing_detail_file}")"
    local _timing_fail=0

    # Check each per-operation field against the 200ms threshold
    local _field
    for _field in auth_to_subscribe_ms subscribe_to_send_ms send_to_receive_ms \
                  mls_encrypt_ms snapshot_persist_ms; do
      local _field_val
      # Use jq type guard: emit the value only when it is a JSON number;
      # any other type (string, null, missing) causes jq to exit non-zero so
      # we treat it as a gate failure rather than coercing it to 0 in awk.
      _field_val=$(jq -r --arg f "${_field}" \
        'if ((.[$f] | type) == "number") then .[$f] else error("non-numeric") end' \
        "${timing_detail_file}" 2>/dev/null || true)
      if [[ -z "${_field_val}" ]]; then
        # Missing or non-numeric field — treat as gate failure so we don't silently skip it
        _timing_fail=1
        break
      fi
      if awk "BEGIN { exit (${_field_val} < 200) ? 0 : 1 }"; then
        : # under threshold
      else
        _timing_fail=1
        break
      fi
    done

    if [[ "${_timing_fail}" -eq 0 ]]; then
      timing_budget_gate="PASS"
    else
      timing_budget_gate="FAIL"
    fi

    # Copy the timing detail file into the run output directory
    cp "${timing_detail_file}" "${output_root}/canonical_flow_timing_detail.json"
  fi

  local body_prefix="qa-${run_id}"

  _qa_run_http_matrix_scenario \
    "S1" \
    "A-tab1" \
    "${a_tab1_token}" \
    "self" \
    "${self_sender_id}" \
    "${body_prefix}-s1-self" \
    "201" \
    "${a_tab1_token}" \
    "${self_sender_id}" \
    "${a_tab2_token}" \
    "${self_sender_topic}" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}"

  _qa_run_http_matrix_scenario \
    "S2" \
    "A-tab1" \
    "${a_tab1_token}" \
    "self" \
    "${self_receiver_id}" \
    "${body_prefix}-s2-spoof" \
    "403,404" \
    "${b_token}" \
    "${self_receiver_id}" \
    "" \
    "" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}" \
    "${b_token}" \
    "${self_receiver_topic}"

  _qa_run_http_matrix_scenario \
    "D1" \
    "A-tab1" \
    "${a_tab1_token}" \
    "direct" \
    "${direct_id}" \
    "${body_prefix}-d1-direct" \
    "201" \
    "${a_tab1_token}" \
    "${direct_id}" \
    "${b_token}" \
    "${direct_topic}" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}"

  _qa_run_http_matrix_scenario \
    "D2" \
    "O" \
    "${outsider_token}" \
    "direct" \
    "${direct_id}" \
    "${body_prefix}-d2-outsider" \
    "404" \
    "${a_tab1_token}" \
    "${direct_id}" \
    "" \
    "" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}" \
    "${b_token}" \
    "${direct_topic}"

  _qa_run_http_matrix_scenario \
    "G1" \
    "A-tab1" \
    "${a_tab1_token}" \
    "group" \
    "${group_id}" \
    "${body_prefix}-g1-group" \
    "201" \
    "${a_tab1_token}" \
    "${group_id}" \
    "${c_token}" \
    "${group_topic}" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}"

  _qa_run_http_matrix_scenario \
    "G2" \
    "O" \
    "${outsider_token}" \
    "group" \
    "${group_id}" \
    "${body_prefix}-g2-outsider" \
    "404" \
    "${a_tab1_token}" \
    "${group_id}" \
    "" \
    "" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}" \
    "${c_token}" \
    "${group_topic}"

  _qa_run_http_matrix_scenario \
    "F1" \
    "A-tab1" \
    "${a_tab1_token}" \
    "family" \
    "${family_id}" \
    "${body_prefix}-f1-family" \
    "201" \
    "${a_tab1_token}" \
    "${family_id}" \
    "${b_token}" \
    "${family_topic}" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}"

  _qa_run_http_matrix_scenario \
    "F2" \
    "O" \
    "${outsider_token}" \
    "family" \
    "${family_id}" \
    "${body_prefix}-f2-outsider" \
    "404" \
    "${a_tab1_token}" \
    "${family_id}" \
    "" \
    "" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}" \
    "${b_token}" \
    "${family_topic}"

  _qa_run_revoked_device_scenario \
    "R1" \
    "A-tab1" \
    "${a_tab1_token}" \
    "A-dev2" \
    "${a_dev2_token}" \
    "${a_dev2_device_id}" \
    "B" \
    "${b_token}" \
    "direct" \
    "${direct_id}" \
    "${direct_topic}" \
    "${body_prefix}-r1-revoked" \
    "${a_tab1_token}" \
    "${direct_id}" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}"

  _qa_run_recovery_rejoin_scenario \
    "R2" \
    "A-tab1" \
    "${a_tab1_token}" \
    "B" \
    "${b_token}" \
    "direct" \
    "${direct_id}" \
    "${direct_topic}" \
    "${body_prefix}-r2-recovery" \
    "${a_tab1_token}" \
    "${direct_id}" \
    "${base_url}" \
    "${ws_base_url}" \
    "${output_root}" \
    "${matrix_csv}"

  local -a scenario_files=(
    "${output_root}/S1/assert.json"
    "${output_root}/S2/assert.json"
    "${output_root}/D1/assert.json"
    "${output_root}/D2/assert.json"
    "${output_root}/G1/assert.json"
    "${output_root}/G2/assert.json"
    "${output_root}/F1/assert.json"
    "${output_root}/F2/assert.json"
    "${output_root}/R1/assert.json"
    "${output_root}/R2/assert.json"
  )

  local scenario_results
  scenario_results="$(jq -s '.' "${scenario_files[@]}")"

  local -a critical_failures=()
  local -a warning_failures=()
  local -a blocked_failures=()
  local scenario_file
  for scenario_file in "${scenario_files[@]}"; do
    local scenario_status
    local scenario_severity
    scenario_status="$(jq -r '.status' "${scenario_file}")"
    scenario_severity="$(jq -r '.severity' "${scenario_file}")"

    if [[ "${scenario_status}" == "BLOCKED" ]]; then
      blocked_failures+=("$(jq -r '.scenario_id' "${scenario_file}")")
    elif [[ "${scenario_status}" == "FAIL" ]]; then
      if [[ "${scenario_severity}" == "S0" || "${scenario_severity}" == "S1" ]]; then
        critical_failures+=("$(jq -r '.scenario_id' "${scenario_file}")")
      else
        warning_failures+=("$(jq -r '.scenario_id' "${scenario_file}")")
      fi
    fi
  done

  local -a global_failures=()
  local -a global_warnings=()

  if [[ "${canonical_status}" == "FAIL" ]]; then
    global_failures+=("canonical_flow")
  fi

  if [[ "${coverage_status}" == "FAIL" ]]; then
    global_warnings+=("canonical_flow_coverage")
  fi

  if [[ "${recovery_contract_status}" == "FAIL" ]]; then
    global_failures+=("recovery_rejoin_contract")
  fi

  if [[ "${continuity_contract_status}" == "FAIL" ]]; then
    global_failures+=("continuity_contract")
  fi

  # G1 gate: MLS failure rate must be < 5%
  if [[ "${mls_failure_gate}" == "FAIL" ]]; then
    global_failures+=("mls_failure_rate")
  fi

  # G2 gate: coverage snapshot must be >= 80%
  if [[ "${coverage_snapshot_gate}" == "FAIL" ]]; then
    global_warnings+=("coverage_snapshot")
  fi

  # G3 gate: per-operation timing budget must be < 200ms
  if [[ "${timing_budget_gate}" == "FAIL" ]]; then
    global_failures+=("timing_budget")
  fi

  local outcome="PASS"
  if [[ "${#blocked_failures[@]}" -gt 0 ]]; then
    outcome="BLOCKED"
  elif [[ "${#critical_failures[@]}" -gt 0 || "${#global_failures[@]}" -gt 0 ]]; then
    outcome="FAIL"
  elif [[ "${#warning_failures[@]}" -gt 0 || "${#global_warnings[@]}" -gt 0 ]]; then
    outcome="WARN"
  fi

  local critical_json
  local warning_json
  local blocked_json
  local global_failures_json
  local global_warnings_json

  critical_json="$(_qa_array_to_json "${critical_failures[@]}")"
  warning_json="$(_qa_array_to_json "${warning_failures[@]}")"
  blocked_json="$(_qa_array_to_json "${blocked_failures[@]}")"
  global_failures_json="$(_qa_array_to_json "${global_failures[@]}")"
  global_warnings_json="$(_qa_array_to_json "${global_warnings[@]}")"

  # G2: coverage_snapshot_pct may be "null" (string) when no file exists;
  # pass as --arg so jq can emit JSON null when the value equals "null".
  local _coverage_pct_json
  if [[ "${coverage_snapshot_pct}" == "null" ]]; then
    _coverage_pct_json="null"
  else
    _coverage_pct_json="${coverage_snapshot_pct}"
  fi

  # G3: timing_detail_json may be "null" (string) when no file exists;
  # pass as --argjson so it is embedded as a JSON object or null.
  local _timing_detail_argjson
  if [[ "${timing_detail_json}" == "null" ]]; then
    _timing_detail_argjson="null"
  else
    _timing_detail_argjson="${timing_detail_json}"
  fi

  jq -n \
    --arg run_id "${run_id}" \
    --arg mode "${mode}" \
    --arg started_at "${started_at}" \
    --arg ended_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg base_url "${base_url}" \
    --arg ws_base_url "${ws_base_url}" \
    --arg outcome "${outcome}" \
    --arg canonical_flow "${canonical_status}" \
    --arg coverage "${coverage_status}" \
    --arg continuity_contract "${continuity_contract_status}" \
    --arg recovery_rejoin_contract "${recovery_contract_status}" \
    --arg mls_failure_rate "${mls_failure_rate}" \
    --arg mls_failure_gate "${mls_failure_gate}" \
    --argjson coverage_snapshot_pct "${_coverage_pct_json}" \
    --arg coverage_snapshot_gate "${coverage_snapshot_gate}" \
    --argjson canonical_flow_elapsed_seconds "${canonical_elapsed}" \
    --arg timing_budget_gate "${timing_budget_gate}" \
    --argjson timing_detail "${_timing_detail_argjson}" \
    --argjson scenarios "${scenario_results}" \
    --argjson critical_failures "${critical_json}" \
    --argjson warning_failures "${warning_json}" \
    --argjson blocked_failures "${blocked_json}" \
    --argjson global_failures "${global_failures_json}" \
    --argjson global_warnings "${global_warnings_json}" \
    '{
      run_id: $run_id,
      mode: $mode,
      started_at: $started_at,
      ended_at: $ended_at,
      base_url: $base_url,
      ws_base_url: $ws_base_url,
      outcome: $outcome,
      canonical_flow: $canonical_flow,
      canonical_flow_elapsed_seconds: $canonical_flow_elapsed_seconds,
      canonical_flow_coverage: $coverage,
      continuity_contract: $continuity_contract,
      recovery_rejoin_contract: $recovery_rejoin_contract,
      mls_failure_rate: ($mls_failure_rate | tonumber),
      mls_failure_gate: $mls_failure_gate,
      coverage_snapshot_pct: $coverage_snapshot_pct,
      coverage_snapshot_gate: $coverage_snapshot_gate,
      timing_budget_gate: $timing_budget_gate,
      timing_detail: $timing_detail,
      scenarios: $scenarios,
      critical_failures: $critical_failures,
      warning_failures: $warning_failures,
      blocked_failures: $blocked_failures,
      global_failures: $global_failures,
      global_warnings: $global_warnings
    }' > "${gate_report}"

  {
    echo "# Messaging QA ${mode^} Run"
    echo ""
    echo "- run_id: \`${run_id}\`"
    echo "- outcome: \`${outcome}\`"
    echo "- canonical_flow: \`${canonical_status}\`"
    echo "- canonical_flow_elapsed_seconds: \`${canonical_elapsed}\`"
    echo "- canonical_flow_coverage: \`${coverage_status}\`"
    echo "- continuity_contract: \`${continuity_contract_status}\`"
    echo "- recovery_rejoin_contract: \`${recovery_contract_status}\`"
    echo "- mls_failure_rate: \`${mls_failure_rate}\` (gate: \`${mls_failure_gate}\`)"
    echo "- coverage_snapshot_pct: \`${coverage_snapshot_pct}\` (gate: \`${coverage_snapshot_gate}\`)"
    echo "- timing_budget_gate: \`${timing_budget_gate}\` (threshold: 200ms per operation)"
    echo "- base_url: \`${base_url}\`"
    echo "- ws_base_url: \`${ws_base_url}\`"
    echo ""
    echo "## Artifacts"
    echo "- seed: \`seed_matrix.json\`"
    echo "- matrix: \`matrix_results.csv\`"
    echo "- gate report: \`gate_report.json\`"
    echo "- continuity contract: \`continuity_contract.txt\`"
    if [[ "${mode}" == "deep" ]]; then
      echo "- recovery contract: \`recovery_rejoin_contract.txt\`"
    fi
  } > "${summary_file}"

  if [[ "${#critical_failures[@]}" -gt 0 ]]; then
    mkdir -p "${project_root}/.tmp/_bugs"
    local bug_file="${project_root}/.tmp/_bugs/list.md"
    local scenario_id
    for scenario_id in "${critical_failures[@]}"; do
      local notes
      notes="$(jq -r '.notes' "${output_root}/${scenario_id}/assert.json")"
      printf -- "- [%s] %s failed: %s\n" \
        "${run_id}" \
        "${scenario_id}" \
        "${notes}" >> "${bug_file}"
    done
  fi

  echo "Messaging QA ${mode} run complete."
  echo "Artifacts: ${output_root}"
  echo "Gate report: ${gate_report}"

  if [[ "${outcome}" == "BLOCKED" ]]; then
    _qa_release_run_lock
    return 2
  fi

  if [[ "${outcome}" == "FAIL" ]]; then
    _qa_release_run_lock
    return 1
  fi

  _qa_release_run_lock
}

function qa:messaging:fast {
  # Live probe matrix for S1..F2 + R1 + R2 (revocation + recovery/rejoin).
  _qa_messaging_run fast "${@}"
}

function qa:messaging:deep {
  # Full live probe matrix plus canonical-flow and recovery-contract artifacts.
  _qa_messaging_run deep "${@}"
}

function elixir:test:coverage {
  echo "GITHUB_EVENT_PATH: $GITHUB_EVENT_PATH"
  
  if [ -z "$GITHUB_EVENT_PATH" ]; then
    echo "Running coverage locally without GitHub Actions environment"
    _dc -e "MIX_ENV=test" web mix coveralls "${@}"
  else
    echo "Running coverage in GitHub Actions environment"
    
    if [ -z "$COVERALLS_REPO_TOKEN" ]; then
      echo "Error: COVERALLS_REPO_TOKEN is not set"
      exit 1
    fi

    BRANCH=${GITHUB_REF#refs/heads/}
    SHA=$GITHUB_SHA
    COMMITTER=$GITHUB_ACTOR

    _dc -e "MIX_ENV=test" \
       -e "GITHUB_TOKEN=${GITHUB_TOKEN}" \
       web mix coveralls.post \
         --token "$COVERALLS_REPO_TOKEN" \
         --branch "$BRANCH" \
         --sha "$SHA" \
         --committer "$COMMITTER" \
         --name "GitHub Actions" \
         "${@}"
  fi
}

function elixir:test:coverage:details {
  # Get test coverage details
  _dc -e "MIX_ENV=test" web mix coveralls.detail "${@}"
}

function elixir:static-analysis {
  # Run Dialyzer static code analysis
  mix dialyzer "${@}"
}

function elixir:static-analysis:ci {
  # Run Dialyzer in CI environment
  _dc -e "MIX_ENV=test" web mix dialyzer --format short
}

function elixir:static-analysis:explain {
  # Explain a Dialyzer warning
  mix dialyzer.explain "${@}"
}

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------

function _rust_manifest_path {
  if [[ -n "${RUST_MANIFEST_PATH:-}" ]]; then
    echo "${RUST_MANIFEST_PATH}"
    return
  fi

  if [[ -f "infra/Cargo.toml" ]]; then
    echo "infra/Cargo.toml"
    return
  fi

  echo ""
}

function _ensure_rust_manifest {
  local manifest_path
  manifest_path="$(_rust_manifest_path)"

  if [[ -z "$manifest_path" ]]; then
    echo "Rust workspace not found. Expected infra/Cargo.toml." >&2
    echo "Set RUST_MANIFEST_PATH to target a different crate/workspace." >&2
    return 2
  fi

  printf "%s" "$manifest_path"
}

function _ensure_rust_toolchain {
  if ! cmd bash -lc "command -v rustc >/dev/null && command -v cargo >/dev/null"; then
    echo "Rust toolchain not available in web container." >&2
    echo "Rebuild the web image after Dockerfile changes:" >&2
    echo "  docker compose build web && docker compose up -d web" >&2
    return 2
  fi
}

function rust:doctor {
  # Show Rust toolchain details and resolved manifest path
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  echo "Rust manifest: ${manifest_path}"
  cmd rustc --version
  cmd cargo --version
}

# shellcheck disable=SC2120
function rust:fmt {
  # Validate Rust formatting
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  cmd cargo fmt --manifest-path "${manifest_path}" --all --check "${@}"
}

# shellcheck disable=SC2120
function rust:clippy {
  # Run strict Rust lints (treat warnings as errors)
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  cmd cargo clippy --manifest-path "${manifest_path}" --all-targets --all-features "${@}" -- -D warnings
}

function rust:lint {
  # Run Rust format and lint checks in a single container exec
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  # shellcheck disable=SC2016
  cmd bash -lc '
    set -o errexit
    set -o pipefail
    manifest_path="$1"
    cargo fmt --manifest-path "$manifest_path" --all --check
    cargo clippy --manifest-path "$manifest_path" --all-targets --all-features -- -D warnings
  ' _ "${manifest_path}"
}

# shellcheck disable=SC2120
function rust:test {
  # Run Rust tests
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  cmd cargo test --manifest-path "${manifest_path}" --all-features "${@}"
}

# shellcheck disable=SC2120
function rust:deny {
  # Run cargo-deny against the workspace dependency graph
  local manifest_path
  local deny_config_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?
  deny_config_path="${RUST_DENY_CONFIG_PATH:-infra/deny.toml}"

  cmd cargo deny --manifest-path "${manifest_path}" check --config "${deny_config_path}" "${@}"
}

function rust:miri {
  # Run Miri tests on nightly (for unsafe boundary validation)
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  cmd rustup +nightly component add miri rust-src
  cmd cargo +nightly miri test --manifest-path "${manifest_path}" --all-features "${@}"
}

function rust:check {
  # Rust oracle loop for LLM/code review workflows in one container exec
  local manifest_path
  manifest_path="$(_ensure_rust_manifest)" || return $?
  _ensure_rust_toolchain || return $?

  # shellcheck disable=SC2016
  cmd bash -lc '
    set -o errexit
    set -o pipefail
    manifest_path="$1"
    shift
    cargo fmt --manifest-path "$manifest_path" --all --check
    cargo clippy --manifest-path "$manifest_path" --all-targets --all-features -- -D warnings
    cargo test --manifest-path "$manifest_path" --all-features "$@"
  ' _ "${manifest_path}" "${@}"
}

function rust:verify {
  # Required Rust validation loop for the workspace
  # shellcheck disable=SC2119
  rust:fmt
  # shellcheck disable=SC2119
  rust:clippy
  wasm:check
  # shellcheck disable=SC2119
  rust:test
  # shellcheck disable=SC2119
  rust:deny
}

# -----------------------------------------------------------------------------
# WASM Spike
# -----------------------------------------------------------------------------

function wasm:check {
  # Check WASM crate builds and compiles cleanly
  cmd cargo check --target wasm32-unknown-unknown --manifest-path "infra/Cargo.toml" --package "mls_wasm"
}

function ci:check-contract {
    # Verify the Rust CI contract stays aligned with the repo commands.
    bash scripts/check-ci-contract.sh
}

function ci:tooling-test {
    # Validate the required Rust check commands against fixture crates.
    bash test/tooling/rust_required_checks_test.sh
}

function wasm:build {
  # Build WASM module for Node.js testing
  # Requires wasm-pack: install with 'curl https://rustwasm.org/wasm-pack/installer/init.sh -sSf | sh'
  if ! command -v wasm-pack >/dev/null 2>&1; then
    echo "wasm-pack not found. Install with:" >&2
    echo "  curl https://rustwasm.org/wasm-pack/installer/init.sh -sSf | sh" >&2
    return 1
  fi

  cd "infra/mls_wasm" || return $?
  wasm-pack build --target nodejs --release
  cd - > /dev/null || return $?
}

function wasm:test {
  # Build WASM and run test harness
  wasm:build || return $?

  cd "infra/mls_wasm" || return $?
  node js/test.mjs
  cd - > /dev/null || return $?
}

