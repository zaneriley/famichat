# -----------------------------------------------------------------------------
# Database Commands
# -----------------------------------------------------------------------------

function db:backup {
  # Dump the current database to ./.backups/. Safe to run while the app is up.
  #
  # Usage: ./run db:backup
  #   Output: ./.backups/backup-YYYYMMDD-HHMMSS.sql

  if ! docker compose ps postgres 2>/dev/null | grep -qE "running|Up"; then
    echo "db:backup: postgres is not running. Start it with: docker compose up -d postgres" >&2
    return 1
  fi

  local pg_user pg_db pg_password backup_file
  pg_user="$(grep -E '^(export )?POSTGRES_USER=' .env 2>/dev/null \
    | sed 's/^[^=]*=//' | tr -d "\"'" | head -1)"
  pg_db="$(grep -E '^(export )?POSTGRES_DB=' .env 2>/dev/null \
    | sed 's/^[^=]*=//' | tr -d "\"'" | head -1)"
  pg_password="$(grep -E '^(export )?POSTGRES_PASSWORD=' .env 2>/dev/null \
    | sed 's/^[^=]*=//' | tr -d "\"'" | head -1)"
  pg_user="${pg_user:-famichat}"
  pg_db="${pg_db:-${pg_user}}"
  backup_file="./.backups/backup-$(date +%Y%m%d-%H%M%S).sql"

  mkdir -p ./.backups
  echo "Backing up '${pg_db}' to ${backup_file}..."
  if docker compose exec -T \
      -e PGPASSWORD="${pg_password}" postgres \
      pg_dump -U "${pg_user}" "${pg_db}" \
      > "${backup_file}" 2>/dev/null; then
    echo "  ✓ Backup saved: ${backup_file}"
  else
    rm -f "${backup_file}"
    echo "  ✗ Backup failed." >&2
    return 1
  fi
}

function db:reset {
  # Nuke the postgres volume and re-run migrations. No Docker rebuild needed.
  # A backup is saved to ./.backups/ automatically before deletion if postgres is reachable.
  #
  # Usage: ./run db:reset [--force]
  #   --force  Skip the confirmation prompt (for scripts and CI)

  local force=false
  for arg in "$@"; do
    case "${arg}" in
      --force|-f) force=true ;;
      *) echo "db:reset: unknown option: ${arg}" >&2; return 1 ;;
    esac
  done

  # Derive the correct volume name from COMPOSE_PROJECT_NAME in .env.
  # $(basename pwd) is wrong when COMPOSE_PROJECT_NAME differs from the directory name.
  local project_name
  project_name="$(grep -E '^(export )?COMPOSE_PROJECT_NAME=' .env 2>/dev/null \
    | sed 's/^[^=]*=//' | tr -d "\"'" | head -1)"
  project_name="${project_name:-$(basename "$(pwd)")}"
  local volume_name="${project_name}_postgres"

  if ! "${force}"; then
    printf '\nThis will permanently delete all data in '\''%s'\'' and start fresh.\n' "${volume_name}"
    printf 'A backup will be saved to ./.backups/ first if postgres is reachable.\n\n'
    read -rp "Reset the database? (y/N) "
    echo
    [[ "${REPLY}" =~ ^[Yy]$ ]] || { echo "Cancelled."; return 0; }
  fi

  echo "Stopping and removing web and postgres containers..."
  docker compose rm -f --stop web postgres

  if docker volume inspect "${volume_name}" >/dev/null 2>&1; then
    echo "Removing volume '${volume_name}'..."
    if docker volume rm "${volume_name}"; then
      echo "  ✓ Volume removed."
    else
      echo "  ✗ Could not remove '${volume_name}' — a container may still be using it." >&2
      echo "    Check with: docker ps -a" >&2
      return 1
    fi
  else
    echo "  Volume '${volume_name}' does not exist — starting from scratch."
  fi

  echo "Starting all services..."
  docker compose up -d

  echo "Waiting for postgres..."
  local attempts=0
  while ! docker compose exec ${TTY} postgres pg_isready -q 2>/dev/null; do
    attempts=$((attempts + 1))
    if [ "${attempts}" -ge 60 ]; then
      echo "  ✗ Postgres did not become ready after 2 minutes." >&2
      return 1
    fi
    sleep 2
  done
  echo "  ✓ Postgres ready."

  echo "Creating database and running migrations..."
  docker compose run --rm -T web mix ecto.create
  docker compose run --rm -T web mix ecto.migrate

  echo "Waiting for web container..."
  local web_attempts=0
  while ! docker compose ps web 2>/dev/null | grep -q "(healthy)"; do
    web_attempts=$((web_attempts + 1))
    if [ "${web_attempts}" -ge 30 ]; then
      echo "  ✗ Web container did not become healthy after 1 minute." >&2
      return 1
    fi
    sleep 2
  done
  echo "  ✓ Web container healthy."

  printf '\n  ✓ Done. All services are up with a fresh database.\n'
  printf '    Seed test data: ./run cmd mix run priv/repo/seeds.exs\n\n'
}

# -----------------------------------------------------------------------------
# CI
# -----------------------------------------------------------------------------

function ci:install-deps {
    # Unchanged
    sudo apt-get install -y curl shellcheck
    sudo curl \
        -L https://raw.githubusercontent.com/nickjj/wait-until/v0.2.0/wait-until \
        -o /usr/local/bin/wait-until && sudo chmod +x /usr/local/bin/wait-until
}

function ci:setup-env {
    cp --no-clobber .env.example .env
    docker compose build
    docker compose up -d

    # shellcheck disable=SC1091
    . .env
    wait-until "docker compose exec -T \
        -e PGPASSWORD=${POSTGRES_PASSWORD} postgres \
        psql -U ${POSTGRES_USER} ${POSTGRES_USER} -c 'SELECT 1'"

    wait-until "docker compose ps web | grep -q '(healthy)'"

    # Populate /mix volume on cold runners (idempotent)
    docker compose exec -T web mix deps.get
    docker compose exec -T web mix compile

    docker compose logs
}

function ci:lint {
    # --- blocking gates ---
    ci:check-contract
    ci:tooling-test
    shell:lint
    lint:dockerfile "${@}"
    docs:boundary-check
    lint:session-keys
    lint:phx-hooks
    elixir:compile:check
    elixir:format:check
    elixir:security-check
    elixir:lint || echo "credo: pre-existing issues (advisory)"
    rust:lint
    # shellcheck disable=SC2119
    rust:deny
    js:fix:check || echo "js:fix:check: pre-existing issues (advisory)"
    css:lint:check || echo "css:lint:check: pre-existing issues (advisory)"
}

function ci:security-check {
    elixir:security-check
}

function ci:setup-db {
    wait-until "docker compose ps web | grep -q '(healthy)'"
    mix ecto.create
    mix ecto.migrate
}

function ci:test {
    ci:check-contract
    wasm:check
    rust:test "${@}"
    elixir:test "${@}"
}

function ci:static-analysis {
    elixir:static-analysis:ci || true
}

function ci:run-all {
    ci:install-deps
    ci:setup-env
    ci:lint "$@"
    ci:security-check
    # ci:setup-db
    ci:test "$@"
    ci:static-analysis
}

# -----------------------------------------------------------------------------
# Unified commands
# -----------------------------------------------------------------------------

function lint:all {
    docs:boundary-check
    elixir:lint
    rust:lint
    js:lint
    css:lint
}

function format:all {
    elixir:format
    js:fix "${@}"
    css:lint
}

function test:all {
    elixir:test "${@}"
    rust:test "${@}"
    js:test
}

function help {
  printf "%s <task> [args]\n\nTasks:\n" "${0}"

  compgen -A function | grep -v "^_" | cat -n

  printf "\nExtended help:\n  Each task has comments for general usage\n"
}

# This idea is heavily inspired by: https://github.com/adriancooney/Taskfile
TIMEFORMAT=$'\nTask completed in %3lR'
time "${@:-help}"
