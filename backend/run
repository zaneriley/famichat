#!/usr/bin/env bash

set -o errexit
set -o pipefail

DC="${DC:-exec}"

# Ensure docker-compose commands run with the host user's uid/gid so the
# container can safely touch bind-mounted files.
HOST_UID="${HOST_UID:-$(id -u)}"
HOST_GID="${HOST_GID:-$(id -g)}"
export HOST_UID HOST_GID

# If we're running in CI we need to disable TTY allocation for docker compose
# commands that enable it by default, such as exec and run.
TTY=""
if [[ ! -t 1 ]]; then
  TTY="-T"
fi

# -----------------------------------------------------------------------------
# Helper functions start with _ and aren't listed in this script's help menu.
# -----------------------------------------------------------------------------

_DOCKER_AVAILABLE=""

function _docker_available {
  # Cache the result so we only check once per ./run invocation.
  # Set FAMICHAT_NATIVE=1 to force native mode (used in CI).
  if [[ -n "${FAMICHAT_NATIVE:-}" ]]; then
    return 1
  fi
  if [[ -z "$_DOCKER_AVAILABLE" ]]; then
    if docker compose ps --status running -q 2>/dev/null | grep -q .; then
      _DOCKER_AVAILABLE=1
    else
      _DOCKER_AVAILABLE=0
    fi
  fi
  [[ "$_DOCKER_AVAILABLE" == "1" ]]
}

function _dc {
  if _docker_available; then
    docker compose "${DC}" ${TTY} "${@}"
    return
  fi

  # Native mode: parse docker-compose exec flags, extract service name,
  # then run the command directly on the host.
  local env_args=()
  local service=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -e)    env_args+=("$2"); shift 2 ;;
      -T)    shift ;;  # TTY flag, not needed natively
      web)   service=web; shift; break ;;
      js)    service=js; shift; break ;;
      postgres) service=postgres; shift; break ;;
      *)     break ;;
    esac
  done

  case "$service" in
    js)
      # JS tools live in assets/node_modules/.bin
      if [[ ${#env_args[@]} -gt 0 ]]; then
        (cd assets && PATH="node_modules/.bin:$PATH" env "${env_args[@]}" "${@}")
      else
        (cd assets && PATH="node_modules/.bin:$PATH" env "${@}")
      fi
      ;;
    *)
      if [[ ${#env_args[@]} -gt 0 ]]; then
        env "${env_args[@]}" "${@}"
      else
        env "${@}"
      fi
      ;;
  esac
}

function _build_run_down {
  docker compose build
  docker compose run ${TTY} "${@}"
  docker compose down
}

# -----------------------------------------------------------------------------

function cmd {
  # Run any command you want in the web container
  _dc web "${@}"
}

# -----------------------------------------------------------------------------
# Elixir
# -----------------------------------------------------------------------------

function mix {
  # Run any mix commands
  echo "Running mix as user: $(id)"
  echo "From directory: $(pwd)"
  echo "Command: mix $*"
  cmd mix "${@}"
}

function mix:install {
  # Install mix dependencies and write lock file
  _build_run_down web mix deps.get
}

function mix:clean {
  # Clean mix dependencies
  _build_run_down web mix deps.clean "$@"
}

function mix:outdated {
  # List any installed packages that are outdated
  mix hex.outdated
}

function iex {
  # Connect to an IEx session
  cmd iex -S mix
}

function secret {
  # Generate a random secret that can be used for secret keys and more
  mix phx.gen.secret
}

function docs {
  # Generate ExDoc documentation
  mix docs
  echo "Documentation generated successfully!"
  echo "View HTML docs at 'doc/index.html'"
  echo "View EPUB docs at 'doc/Famichat.epub'"
}

function docs:boundary-check {
  # Check IA/DDD naming boundary drift in active docs.
  if ! command -v rg >/dev/null 2>&1; then
    echo "ripgrep (rg) not found, skipping docs:boundary-check" >&2
    return 0
  fi

  local project_root
  project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

  local -a docs_files=(
    "${project_root}/docs/SPEC.md"
    "${project_root}/docs/NOW.md"
    "${project_root}/docs/E2EE_INTEGRATION.md"
    "${project_root}/docs/decisions/012-spa-wasm-client-architecture.md"
    "${project_root}/docs/brand-positioning.md"
    "${project_root}/docs/DECISIONS.md"
  )

  local -a patterns=(
    "\\bConversationEncryptionPolicy\\b"
    "\\bConversationTypePolicy\\b"
    "\\bmessage security state\\b"
    "\\bMLSStateStore\\b"
    "\\bencryption policy\\b"
    "\\bkey[- ]package inventory policy\\b"
    "\\bCookieOrBearerAuth\\b"
    "\\bCryptoService\\b"
    "\\bWorkerSupervisor\\b"
    "\\bboot[_ ]token\\b"
    "\\bchannel_bootstrap_token\\b"
  )

  local -a suggestions=(
    "Use Famichat.Chat.ConversationSecurityPolicy."
    "Use ConversationTypePolicy only for broader conversation-type concerns, not security-only policy."
    "Use conversation security state for durable conversation-scoped security state."
    "Use Famichat.Chat.ConversationSecurityStateStore and keep protocol as data."
    "Use conversation security policy for chat-domain policy wording."
    "Use client inventory policy wording at Chat boundary docs; keep key_package terms scoped to MLS adapter/internal payload context."
    "Use ApiAuth — names the capability, not the mechanism."
    "Use ConversationCrypto (domain interface) or MlsWorkerApi (protocol interface)."
    "Use CryptoWorkerManager — avoids OTP Supervisor collision."
    "Use boot context — sessionStorage.__boot_token superseded by cookie-based auth."
    "Use channel_token — canonical term; endpoint is POST /api/v1/auth/channel_tokens."
  )

  local violations=0
  local i
  for i in "${!patterns[@]}"; do
    local matches
    matches="$(rg -n -H -i --pcre2 "${patterns[$i]}" "${docs_files[@]}" || true)"

    if [[ -n "${matches}" ]]; then
      violations=$((violations + 1))
      echo "Boundary drift rule hit: ${patterns[$i]}" >&2
      echo "${matches}" >&2
      echo "Suggestion: ${suggestions[$i]}" >&2
      echo "" >&2
    fi
  done

  if [[ "${violations}" -gt 0 ]]; then
    echo "Docs IA/DDD boundary check failed (${violations} rule group(s))." >&2
    return 1
  fi

  echo "Docs IA/DDD boundary check passed ✅"
}

function lint:session-keys {
  # Enforce canonical Plug session key accessors (FamichatWeb.SessionKeys).
  if ! command -v rg >/dev/null 2>&1; then
    echo "ripgrep (rg) not found, skipping lint:session-keys" >&2
    return 0
  fi

  local project_root
  project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

  if rg -n \
    'get_session\([^,\n]+,\s*("access_token"|"refresh_token"|"device_id"|"user_locale"|"redirect_count"|"invite_token"|:access_token|:refresh_token|:device_id|:user_locale|:redirect_count|:invite_token)\)|put_session\([^,\n]+,\s*("access_token"|"refresh_token"|"device_id"|"user_locale"|"redirect_count"|"invite_token"|:access_token|:refresh_token|:device_id|:user_locale|:redirect_count|:invite_token)\)' \
    "${project_root}/backend/lib" "${project_root}/backend/test"; then
    echo "Use FamichatWeb.SessionKeys for Plug session accessors." >&2
    return 1
  fi

  echo "Session key lint passed ✅"
}

function lint:phx-hooks {
  # Ensure every phx-hook in templates is registered in app.js.
  if ! command -v rg >/dev/null 2>&1; then
    echo "ripgrep (rg) not found, skipping lint:phx-hooks" >&2
    return 0
  fi

  local hooks_in_templates
  hooks_in_templates=$(rg 'phx-hook="([^"]+)"' lib --only-matching --no-filename \
    | sed 's/phx-hook="//;s/"//' | sort -u) || true

  local failed=0
  for hook in $hooks_in_templates; do
    if ! grep -qE "^\s+$hook\s*:" assets/js/app.js; then
      echo "ERROR: phx-hook=\"$hook\" used in templates but not registered in assets/js/app.js" >&2
      failed=1
    fi
  done

  if [[ "$failed" -eq 0 ]]; then
    echo "All phx-hook names registered ✅"
  else
    return 1
  fi
}

function lint:dockerfile {
  # Lint Dockerfile, preferring local hadolint for speed.
  if command -v hadolint >/dev/null 2>&1; then
    hadolint --ignore DL3008 --ignore DL4006 -t style "${@}" Dockerfile
    return
  fi

  docker container run --rm -i \
    hadolint/hadolint hadolint --ignore DL3008 --ignore DL4006 -t style "${@}" - < Dockerfile
}

function shell:lint {
  # Lint shell scripts, preferring local shellcheck for speed.
  local files=(run bin/* scripts/*.sh test/tooling/*.sh)

  if command -v shellcheck >/dev/null 2>&1; then
    shellcheck "${files[@]}"
    return
  fi

  echo "shellcheck not found locally; using koalaman/shellcheck:stable (slower)." >&2
  docker container run --rm \
    -v "$(pwd)":/workdir \
    -w /workdir \
    koalaman/shellcheck:stable \
    "${files[@]}"
}

