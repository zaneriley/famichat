#!/usr/bin/env bash

set -euo pipefail

CURRENT_APP_NAME="famichat"
CURRENT_MODULE_NAME="Famichat"
CURRENT_APP_NAME_UPPER="${CURRENT_APP_NAME^^}"

DRY_RUN=0
ASSUME_YES=0

usage() {
  cat <<'EOF'
Usage:
  backend/bin/rename-project [--dry-run] [--yes] <new_app_name> <NewModuleName>

Examples:
  backend/bin/rename-project familychat Familychat
  backend/bin/rename-project --dry-run kinchat Kinchat

What it does:
  - Renames paths containing famichat / Famichat
  - Rewrites text files across the repo from famichat / Famichat / FAMICHAT
  - Leaves Docker volumes and git history alone

What it does not do:
  - Rename the repo root directory
  - Reset your database
  - Reinitialize git
EOF
}

log() {
  printf '%s\n' "$1"
}

fail() {
  printf 'rename-project: %s\n' "$1" >&2
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --yes)
      ASSUME_YES=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      fail "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -ne 2 ]]; then
  usage
  exit 1
fi

NEW_APP_NAME="$1"
NEW_MODULE_NAME="$2"
NEW_APP_NAME_UPPER="${NEW_APP_NAME^^}"

[[ "$NEW_APP_NAME" =~ ^[a-z][a-z0-9_]*$ ]] || fail "app name must match ^[a-z][a-z0-9_]*$"
[[ "$NEW_MODULE_NAME" =~ ^[A-Z][A-Za-z0-9]*$ ]] || fail "module name must match ^[A-Z][A-Za-z0-9]*$"
[[ "$NEW_APP_NAME" != "$CURRENT_APP_NAME" ]] || fail "new app name must differ from ${CURRENT_APP_NAME}"
[[ "$NEW_MODULE_NAME" != "$CURRENT_MODULE_NAME" ]] || fail "new module name must differ from ${CURRENT_MODULE_NAME}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

prune_expr=(
  -name .git -o
  -name .tmp -o
  -name _build -o
  -name deps -o
  -name node_modules -o
  -name target -o
  -path "*/priv/static/*"
)

text_files() {
  find "${PROJECT_ROOT}" \
    \( "${prune_expr[@]}" \) -prune -o \
    -type f -print
}

rename_candidates() {
  find "${PROJECT_ROOT}" -mindepth 1 -depth \
    \( "${prune_expr[@]}" \) -prune -o \
    \( -name "*${CURRENT_APP_NAME}*" -o -name "*${CURRENT_MODULE_NAME}*" -o -name "*${CURRENT_APP_NAME_UPPER}*" \) \
    -print
}

is_text_file() {
  local file="$1"
  grep -Iq . "$file"
}

replace_in_file() {
  local file="$1"
  local find="$2"
  local replace="$3"

  if ! grep -q --fixed-strings "$find" "$file"; then
    return 0
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "update ${file#"$PROJECT_ROOT"/}: ${find} -> ${replace}"
    return 0
  fi

  FIND="$find" REPLACE="$replace" perl -0pi -e 's/\Q$ENV{FIND}\E/$ENV{REPLACE}/g' "$file"
}

rename_path() {
  local path="$1"
  local relative_path="${path#"$PROJECT_ROOT"/}"
  local target_relative="$relative_path"
  local target

  target_relative="${target_relative//${CURRENT_MODULE_NAME}/${NEW_MODULE_NAME}}"
  target_relative="${target_relative//${CURRENT_APP_NAME_UPPER}/${NEW_APP_NAME_UPPER}}"
  target_relative="${target_relative//${CURRENT_APP_NAME}/${NEW_APP_NAME}}"
  target="${PROJECT_ROOT}/${target_relative}"

  if [[ "$relative_path" == "$target_relative" ]]; then
    return 0
  fi

  if [[ -e "$target" ]]; then
    fail "refusing to overwrite existing path: ${target_relative}"
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "rename ${relative_path} -> ${target_relative}"
    return 0
  fi

  mv "$path" "$target"
}

log "Rename plan"
log "  repo root: ${PROJECT_ROOT}"
log "  app name: ${CURRENT_APP_NAME} -> ${NEW_APP_NAME}"
log "  module:   ${CURRENT_MODULE_NAME} -> ${NEW_MODULE_NAME}"

if [[ "$DRY_RUN" -eq 0 && "$ASSUME_YES" -eq 0 ]]; then
  printf 'Proceed? [y/N] '
  read -r answer
  case "$answer" in
    [Yy]|[Yy][Ee][Ss]) ;;
    *)
      log "Aborted."
      exit 1
      ;;
  esac
fi

while IFS= read -r path; do
  rename_path "$path"
done < <(rename_candidates)

while IFS= read -r file; do
  if ! is_text_file "$file"; then
    continue
  fi

  replace_in_file "$file" "$CURRENT_MODULE_NAME" "$NEW_MODULE_NAME"
  replace_in_file "$file" "$CURRENT_APP_NAME_UPPER" "$NEW_APP_NAME_UPPER"
  replace_in_file "$file" "$CURRENT_APP_NAME" "$NEW_APP_NAME"
done < <(text_files)

if [[ "$DRY_RUN" -eq 1 ]]; then
  log "Dry run complete."
else
  log "Rename complete."
  log "Review the diff before committing."
fi
